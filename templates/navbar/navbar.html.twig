<style>
  .custom-navbar {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 12px 20px;
  }
  .navbar-brand { font-size:1.3rem; letter-spacing:1px; }
  .nav-link { color:rgba(255,255,255,0.75) !important; font-weight:500; transition:0.3s ease; }
  .nav-link:hover { color:white !important; }
  .nav-link.active { color:#c9a84c !important; }
  .login-btn {
    background: linear-gradient(135deg, #7b2ff7, #f107a3);
    color:white; text-decoration:none; padding:10px 20px;
    border-radius:12px; font-weight:600; transition:0.2s;
  }
  .login-btn:hover { color:white; opacity:0.9; }
  .user-badge {
    display:flex; align-items:center; gap:10px;
    color:rgba(255,255,255,0.8); font-weight:500; font-size:0.9rem;
  }
  .user-avatar {
    width:36px; height:36px; border-radius:50%;
    background: linear-gradient(135deg, #7b2ff7, #f107a3);
    display:flex; align-items:center; justify-content:center;
    color:white; font-weight:700; font-size:0.85rem;
  }
  .logout-btn {
    color:rgba(255,255,255,0.5); text-decoration:none;
    font-size:0.85rem; padding:6px 14px; border-radius:8px;
    border:1px solid rgba(255,255,255,0.1); transition:0.2s;
  }
  .logout-btn:hover { color:white; border-color:rgba(239,68,68,0.4); background:rgba(239,68,68,0.1); }
</style>

<nav class="navbar navbar-expand-lg custom-navbar mb-5">
  <div class="container">
    <a class="navbar-brand fw-bold text-white" href="{{ path('app_club_index') }}">ISET Zaghouan</a>

    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarContent">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">
        <li class="nav-item">
          <a class="nav-link" href="{{ path('app_club_index') }}">Accueil</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="{{ path('app_club_index') }}">Clubs</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="{{ path('app_evenement_index') }}">Événements</a>
        </li>

        {% if app.user %}
          <li class="nav-item ms-lg-2">
            <div class="user-badge">
              <a href="{{ path('app_dashboard') }}" class="text-decoration-none text-white">
                <div class="user-avatar">{{ app.user.prenom|slice(0,1)|upper }}{{ app.user.nom|slice(0,1)|upper }}</div>
              </a>
              <span class="d-none d-lg-inline">{{ app.user.prenom }}</span>
            </div>
          </li>
          <li class="nav-item">
            <a class="logout-btn" href="{{ path('app_logout') }}">Déconnexion</a>
          </li>
        {% else %}
          <li class="nav-item ms-lg-2">
            <a class="login-btn" href="{{ path('app_login') }}">Connexion</a>
          </li>
        {% endif %}
      </ul>
    </div>
  </div>
</nav>
