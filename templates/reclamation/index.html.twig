{% extends 'base.html.twig' %}
{% block title %}Réclamations{% endblock %}
{% block body %}
<div class="container mt-4">
    <h1>Réclamations</h1>
    <a href="{{ path('reclamation_new') }}" class="btn btn-primary mb-3">+ Nouvelle réclamation</a>
    <table class="table table-bordered">
        <thead><tr><th>Sujet</th><th>Étudiant</th><th>Statut</th><th>Date</th><th>Actions</th></tr></thead>
        <tbody>
        {% for r in reclamations %}
        <tr>
            <td>{{ r.subject }}</td>
            <td>{{ r.user.prenom }} {{ r.user.nom }}</td>
            <td><span class="badge bg-{{ r.status == 'closed' ? 'success' : (r.status == 'processed' ? 'info' : 'warning') }}">{{ r.status }}</span></td>
            <td>{{ r.createdAt|date('d/m/Y') }}</td>
            <td>
                <form action="{{ path('reclamation_status', {id: r.id, status: 'processed'}) }}" method="post" style="display:inline">
                    <button class="btn btn-sm btn-info">Traiter</button>
                </form>
                <form action="{{ path('reclamation_status', {id: r.id, status: 'closed'}) }}" method="post" style="display:inline">
                    <button class="btn btn-sm btn-success">Clôturer</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="5">Aucune réclamation.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}