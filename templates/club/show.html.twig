{% extends 'base.html.twig' %}

{% block title %}{{ club.name }}{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

<div class="club-page py-4">
    <div class="container">

        <div class="mb-4">
            <a href="{{ path('app_club_index') }}" class="back-link">
                ← Retour à la liste
            </a>
        </div>

        <div class="show-card">

            <!-- HERO TOP -->
            <div class="show-hero">
                <div class="hero-glow"></div>

                <div class="d-flex flex-column flex-md-row align-items-center gap-4">

                    <!-- LOGO -->
                    <div class="logo-wrapper">
                        {% if club.logo %}
                            <img src="{{ asset('uploads/logos/' ~ club.logo) }}"
                                 alt="{{ club.name }}" class="club-logo-img">
                        {% else %}
                            <div class="logo-initial">{{ club.name|slice(0,1)|upper }}</div>
                        {% endif %}
                    </div>

                    <!-- TITLE + META -->
                    <div class="flex-grow-1">
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="domain-badge">{{ club.domain }}</span>
                            {% if club.status %}
                                <span class="status active">● Actif</span>
                            {% else %}
                                <span class="status inactive">● Fermé</span>
                            {% endif %}
                        </div>
                        <h1 class="show-title">{{ club.name }}</h1>
                        <p class="show-description">{{ club.description ?? '' }}</p>

                        {% if club.website %}
                            <a href="{{ club.website }}" target="_blank" class="website-link mt-2 d-inline-block">
                                🌐 {{ club.website }}
                            </a>
                        {% endif %}
                    </div>

                </div>

                <!-- ACTION BUTTONS -->
                <div class="d-flex gap-2 mt-4 justify-content-end flex-wrap">
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_club_edit', {'id': club.id}) }}" class="action-btn edit-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Modifier
        </a>
        {{ include('club/_delete_form.html.twig') }}
    {% endif %}
</div>

            </div>

            <!-- DETAILS SECTION -->
            <div class="details-section">

                <h2 class="section-heading">Informations du club</h2>

                <div class="details-grid">

                    <div class="detail-item">
                        <div class="detail-icon">🏷️</div>
                        <div>
                            <span class="detail-label">Nom du club</span>
                            <span class="detail-value">{{ club.name }}</span>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="detail-icon">📂</div>
                        <div>
                            <span class="detail-label">Domaine</span>
                            <span class="detail-value">{{ club.domain ?? '—' }}</span>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="detail-icon">📌</div>
                        <div>
                            <span class="detail-label">Statut</span>
                            <span class="detail-value">
                                {% if club.status %}
                                    <span class="status active">● Actif</span>
                                {% else %}
                                    <span class="status inactive">● Fermé</span>
                                {% endif %}
                            </span>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="detail-icon">🌐</div>
                        <div>
                            <span class="detail-label">Site web</span>
                            <span class="detail-value">
                                {% if club.website %}
                                    <a href="{{ club.website }}" target="_blank" class="website-link">
                                        {{ club.website }}
                                    </a>
                                {% else %}
                                    —
                                {% endif %}
                            </span>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="detail-icon">📅</div>
                        <div>
                            <span class="detail-label">Créé le</span>
                            <span class="detail-value">
                                {{ club.createdAt ? club.createdAt|date('d/m/Y à H:i') : '—' }}
                            </span>
                        </div>
                    </div>

                </div>

                {% if club.description %}
                <div class="description-block mt-4">
                    <div class="detail-icon mb-2">📝</div>
                    <span class="detail-label d-block mb-2">Description complète</span>
                    <p class="description-text">{{ club.description }}</p>
                </div>
                {% endif %}

            </div>

        </div>

    </div>
</div>

<style>

body {
    min-height: 100vh;
    background-color: #292222;
    position: relative;
}

::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(241,234,234,0.862); border-radius: 20px; }

body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url('/background/background.jpg');
    background-repeat: no-repeat;
    background-position: center top;
    background-size: cover;
    opacity: 0.4;
    filter: blur(2px);
    z-index: -2;
    pointer-events: none;
}

.club-page { min-height: 100vh; }

.back-link {
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: 0.2s;
}
.back-link:hover { color: white; }

/* MAIN CARD */
.show-card {
    background: rgba(255,255,255,0.07);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.2);
}

/* HERO */
.show-hero {
    padding: 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    position: relative;
    overflow: hidden;
    background: rgba(255,255,255,0.03);
}

.hero-glow {
    position: absolute;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(123,47,247,0.12), transparent 70%);
    top: -150px; right: -100px;
    pointer-events: none;
}

/* LOGO */
.logo-wrapper {
    flex-shrink: 0;
    width: 280px;
    height: 220px;
    border-radius: 20px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
}
.club-logo-img {
    width: 100%;
    height: 100%;
    object-fit: cover; 
    padding: 0;    
}
.logo-initial {
    font-size: 6rem;
    font-weight: 800;
    color: white;
    background: linear-gradient(135deg, #7b2ff7, #f107a3);
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    border-radius: 20px;
}

/* TITLE */
.show-title {
    font-size: 2rem;
    font-weight: 800;
    color: #ffffff;
    margin: 6px 0 8px;
    line-height: 1.2;
}
.show-description {
    color: rgba(255,255,255,0.75);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
    max-width: 600px;
}

/* BADGES */
.domain-badge {
    background: rgba(123,47,247,0.25);
    border: 1px solid rgba(123,47,247,0.4);
    color: #d8b4fe;
    padding: 4px 13px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
}

.status { padding: 4px 12px; border-radius: 50px; font-size: 0.78rem; font-weight: 600; }
.status.active   { background: rgba(25,135,84,0.2);  color: #4ade80; border: 1px solid rgba(74,222,128,0.25); }
.status.inactive { background: rgba(220,53,69,0.2);  color: #ff6b81; border: 1px solid rgba(255,107,129,0.25); }

.website-link {
    color: #d8b4fe;
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
}
.website-link:hover { color: white; }

/* ACTION BUTTONS */
.action-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 20px; border-radius: 12px;
    font-size: 0.85rem; font-weight: 600;
    text-decoration: none; transition: 0.2s ease;
    cursor: pointer; border: none;
}
.edit-btn {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.9);
}
.edit-btn:hover {
    background: rgba(168,85,247,0.25);
    border-color: #a855f7;
    color: white;
}

/* DETAILS SECTION */
.details-section {
    padding: 2.5rem;
}

.section-heading {
    font-size: 0.78rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 1.5rem;
}

.details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
}

.detail-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 1.1rem 1.25rem;
    transition: 0.2s;
}
.detail-item:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(168,85,247,0.35);
    transform: translateY(-2px);
}

.detail-icon {
    font-size: 1.4rem;
    line-height: 1;
    margin-top: 2px;
    flex-shrink: 0;
}

.detail-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 4px;
}
.detail-value {
    display: block;
    font-size: 0.92rem;
    color: rgba(255,255,255,0.95);
    font-weight: 500;
    line-height: 1.5;
}

/* DESCRIPTION BLOCK */
.description-block {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 16px;
    padding: 1.5rem;
}
.description-text {
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0;
    white-space: pre-line;
}

</style>

{% endblock %}