{% extends 'base.html.twig' %}

{% block title %}{{ club.name }}{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

{# ── Animated blob background ── #}
<div class="blob-bg" id="blobBg" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>
</div>

<div class="club-page py-4">
    <div class="container">

        <div class="mb-4">
            <a href="{{ path('app_club_index') }}" class="back-link">
                ← Retour à la liste
            </a>
        </div>

        <div class="show-card">

            <!-- HERO TOP -->
            <div class="show-hero">
                <div class="hero-glow"></div>

                <div class="d-flex flex-column flex-md-row align-items-center gap-4">

                    <!-- LOGO -->
                    <div class="logo-wrapper">
                        {% if club.logo %}
                            <img src="{{ asset('uploads/logos/' ~ club.logo) }}"
                                 alt="{{ club.name }}" class="club-logo-img">
                        {% else %}
                            <div class="logo-initial">{{ club.name|slice(0,1)|upper }}</div>
                        {% endif %}
                    </div>

                    <!-- TITLE + META -->
                    <div class="flex-grow-1">
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="domain-badge">{{ club.domain }}</span>
                            {% if club.status %}
                                <span class="status active">● Actif</span>
                            {% else %}
                                <span class="status inactive">● Fermé</span>
                            {% endif %}
                        </div>
                        <h1 class="show-title">{{ club.name }}</h1>
                        <p class="show-description">{{ club.description ?? '' }}</p>

                        {% if club.website %}
                            <a href="//{{ club.website }}" target="_blank" class="website-link mt-2 d-inline-block">
                                🌐 {{ club.website }}
                            </a>
                        {% endif %}
                    </div>

                </div>

                <!-- ACTION BUTTONS -->
                <div class="d-flex gap-2 mt-4 justify-content-end flex-wrap">
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_club_edit', {'id': club.id}) }}" class="action-btn edit-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Modifier
        </a>
        {{ include('club/_delete_form.html.twig') }}
    {% endif %}
    {% if is_granted('ROLE_ADMIN') or (app.user and club.clubMembers|filter(m => m.user == app.user and m.role == 'President')|length > 0) %}
        <a href="{{ path('app_club_manage', {'id': club.id}) }}" class="action-btn manage-btn">
            ⚙️ Gérer
        </a>
    {% endif %}
</div>

            </div>

            <!-- DETAILS SECTION -->
            <div class="details-section">

                <h2 class="section-heading">Informations du club</h2>

                <div class="details-grid">

                    <div class="detail-item">
                        <div class="detail-icon">🏷️</div>
                        <div>
                            <span class="detail-label">Nom du club</span>
                            <span class="detail-value">{{ club.name }}</span>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="detail-icon">📂</div>
                        <div>
                            <span class="detail-label">Domaine</span>
                            <span class="detail-value">{{ club.domain ?? '—' }}</span>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="detail-icon">📌</div>
                        <div>
                            <span class="detail-label">Statut</span>
                            <span class="detail-value">
                                {% if club.status %}
                                    <span class="status active">● Actif</span>
                                {% else %}
                                    <span class="status inactive">● Fermé</span>
                                {% endif %}
                            </span>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="detail-icon">🌐</div>
                        <div>
                            <span class="detail-label">Site web</span>
                            <span class="detail-value">
                                {% if club.website %}
                                    <a href="//{{ club.website }}" target="_blank" class="website-link">
                                        {{ club.website }}
                                    </a>
                                {% else %}
                                    —
                                {% endif %}
                            </span>
                        </div>
                    </div>

                    <div class="detail-item">
                        <div class="detail-icon">📅</div>
                        <div>
                            <span class="detail-label">Créé le</span>
                            <span class="detail-value">
                                {{ club.createdAt ? club.createdAt|date('d/m/Y à H:i') : '—' }}
                            </span>
                        </div>
                    </div>


                    <div class="detail-item">
                        <div class="detail-icon">👥</div>
                        <div>
                            <span class="detail-label">Nombre de membres</span>
                            <span class="detail-value">
                                {{ club.ClubMembers|length }} / {{ club.maxMembers }}
                            </span>
                        </div>
                    </div>

                </div>

                {% if club.description %}
                <div class="description-block mt-4">
                    <div class="detail-icon mb-2">📝</div>
                    <span class="detail-label d-block mb-2">Description complète</span>
                    <p class="description-text">{{ club.description }}</p>
                </div>
                {% endif %}

            </div>

            <!-- RECRUTEMENTS SECTION -->
            {% set openRecrutements = club.recrutements|filter(r => r.status == 'open') %}
            {% if openRecrutements|length > 0 %}
            <div class="details-section">
                <h2 class="section-heading">Recrutements ouverts</h2>
                <div class="row g-3">
                    {% for recrutement in openRecrutements %}
                    <div class="col-md-6">
                        <div class="recrutement-card">
                            <h3 class="recrutement-title">{{ recrutement.title }}</h3>
                            {% if recrutement.description %}
                                <p class="recrutement-desc">{{ recrutement.description }}</p>
                            {% endif %}
                            {% if recrutement.requirements %}
                                <div class="recrutement-reqs">
                                    <span class="reqs-label">Prérequis :</span>
                                    {{ recrutement.requirements }}
                                </div>
                            {% endif %}
                            {% if recrutement.deadline %}
                                <div class="recrutement-deadline">
                                    ⏳ Date limite : {{ recrutement.deadline|date('d/m/Y') }}
                                </div>
                            {% endif %}
                            <a href="{{ path('candidature_new', {'recrutementId': recrutement.id}) }}" class="postuler-btn mt-3">
                                Postuler →
                            </a>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

        </div>

    </div>
</div>

<style>

/* ── Animated blob background ── */
.blob-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background: radial-gradient(ellipse at 70% 40%, #e84c0e 0%, #b81c05 35%, #7a0a0e 65%, #2d0520 100%);
}

.blob {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: screen;
    filter: blur(2px);
}

.blob-1 {
    width: 340px; height: 340px;
    background: radial-gradient(circle at 40% 35%, #ffaa00, #e85c00 55%, transparent 80%);
    top: -60px; right: 100px;
    animation: float1 9s ease-in-out infinite;
}
.blob-2 {
    width: 180px; height: 180px;
    background: radial-gradient(circle at 45% 40%, #ffd060, #ff8800 60%, transparent 80%);
    top: 20px; right: 330px;
    animation: float2 11s ease-in-out infinite;
}
.blob-3 {
    width: 420px; height: 360px;
    background: radial-gradient(circle at 50% 45%, #ff6a00 0%, #dd2200 50%, transparent 75%);
    bottom: -100px; right: -40px;
    animation: float3 13s ease-in-out infinite;
}
.blob-4 {
    width: 260px; height: 200px;
    background: radial-gradient(circle at 50% 50%, #ff4500 0%, #9e0a00 55%, transparent 80%);
    bottom: 20px; left: 80px;
    animation: float4 10s ease-in-out infinite;
}
.blob-5 {
    width: 90px; height: 90px;
    background: radial-gradient(circle at 45% 40%, #ffc040, #ff7800 60%, transparent 80%);
    top: 130px; right: 260px;
    animation: float5 7s ease-in-out infinite;
}

.sparkle {
    position: absolute;
    width: 3px; height: 3px;
    background: rgba(255,255,255,0.55);
    border-radius: 50%;
}

@keyframes float1 {
    0%,100% { transform: translate(0,0) scale(1); }
    33% { transform: translate(-18px, 22px) scale(1.04); }
    66% { transform: translate(12px, -14px) scale(0.97); }
}
@keyframes float2 {
    0%,100% { transform: translate(0,0) scale(1); }
    40% { transform: translate(20px, 18px) scale(1.06); }
    70% { transform: translate(-10px, -8px) scale(0.95); }
}
@keyframes float3 {
    0%,100% { transform: translate(0,0) scale(1); }
    30% { transform: translate(-25px, -20px) scale(1.03); }
    60% { transform: translate(15px, 12px) scale(0.98); }
}
@keyframes float4 {
    0%,100% { transform: translate(0,0) scale(1); }
    45% { transform: translate(22px, -18px) scale(1.05); }
    75% { transform: translate(-12px, 10px) scale(0.96); }
}
@keyframes float5 {
    0%,100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(-14px, 20px) scale(1.1); }
}

body {
    min-height: 100vh;
}

::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,200,170,0.2); border-radius: 20px; }

.club-page .container {
    max-width: 1480px;
}
.club-page { min-height: 100vh; }

.back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,200,170,0.6);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 7px 16px;
    border-radius: 50px;
    border: 1px solid rgba(255,140,50,0.15);
    background: rgba(232,92,0,0.08);
    transition: 0.2s ease;
}
.back-link:hover {
    color: white;
    background: rgba(232,92,0,0.18);
}

/* MAIN CARD */
.show-card {
    background: rgba(18, 5, 20, 0.5);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(255,140,50,0.12);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3);
}

/* HERO */
.show-hero {
    padding: 2.5rem;
    border-bottom: 1px solid rgba(255,140,50,0.06);
    position: relative;
    overflow: hidden;
    background: rgba(232,92,0,0.03);
}

.hero-glow {
    position: absolute;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(232,92,0,0.1), transparent 70%);
    top: -150px; right: -100px;
    pointer-events: none;
}

/* LOGO */
.logo-wrapper {
    flex-shrink: 0;
    width: 260px;
    height: 200px;
    border-radius: 20px;
    background: rgba(18,5,20,0.5);
    border: 1px solid rgba(255,140,50,0.15);
    backdrop-filter: blur(10px);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
}
.club-logo-img {
    width: 100%;
    height: 100%;
    object-fit: cover; 
    padding: 0;    
}
.logo-initial {
    font-size: 6rem;
    font-weight: 800;
    color: white;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    border-radius: 20px;
}

/* TITLE */
.show-title {
    font-size: 2rem;
    font-weight: 800;
    color: #ffffff;
    margin: 6px 0 8px;
    line-height: 1.2;
}
.show-description {
    color: rgba(255,200,170,0.75);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
    max-width: 600px;
}

/* BADGES */
.domain-badge {
    background: rgba(232,92,0,0.15);
    border: 1px solid rgba(255,140,50,0.3);
    color: #ff9944;
    padding: 4px 13px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
}

.status { padding: 4px 12px; border-radius: 50px; font-size: 0.78rem; font-weight: 600; }
.status.active   { background: rgba(232,92,0,0.12);  color: #ff9944; border: 1px solid rgba(255,153,68,0.25); }
.status.inactive { background: rgba(220,53,69,0.12);  color: #ff6b81; border: 1px solid rgba(255,107,129,0.2); }

.website-link {
    color: rgba(255,180,120,0.8);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
}
.website-link:hover { color: #ff9944; }

/* ACTION BUTTONS */
.action-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 20px; border-radius: 12px;
    font-size: 0.85rem; font-weight: 600;
    text-decoration: none; transition: 0.2s ease;
    cursor: pointer; border: none;
}
.edit-btn {
    background: rgba(232,92,0,0.08);
    border: 1px solid rgba(255,140,50,0.15);
    color: rgba(255,220,190,0.9);
}
.edit-btn:hover {
    background: rgba(232,92,0,0.18);
    border-color: #ff8c42;
    color: white;
}

.manage-btn {
    background: rgba(99,102,241,0.1);
    border: 1px solid rgba(165,180,252,0.25);
    color: rgba(200,190,255,0.9);
}
.manage-btn:hover {
    background: rgba(99,102,241,0.2);
    border-color: #a5b4fc;
    color: white;
}

/* Recrutement cards */
.recrutement-card {
    background: rgba(18,5,20,0.4);
    border: 1px solid rgba(255,140,50,0.08);
    border-radius: 16px;
    padding: 1.25rem;
    height: 100%;
    transition: 0.2s;
}
.recrutement-card:hover {
    background: rgba(232,92,0,0.06);
    border-color: rgba(255,140,50,0.2);
    transform: translateY(-2px);
}
.recrutement-title {
    font-size: 1rem;
    font-weight: 700;
    color: white;
    margin-bottom: 8px;
}
.recrutement-desc {
    color: rgba(255,200,170,0.7);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 10px;
}
.recrutement-reqs {
    color: rgba(255,200,170,0.6);
    font-size: 0.82rem;
    margin-bottom: 6px;
}
.reqs-label {
    color: rgba(255,200,170,0.4);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.5px;
}
.recrutement-deadline {
    color: rgba(255,200,170,0.5);
    font-size: 0.82rem;
}
.postuler-btn {
    display: inline-block;
    padding: 8px 18px;
    border-radius: 10px;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: 0.2s ease;
    box-shadow: 0 4px 14px rgba(232,92,0,0.3);
}
.postuler-btn:hover { opacity: 0.92; color: white; transform: scale(1.02); }

/* DETAILS SECTION */
.details-section {
    padding: 2.5rem;
}

.section-heading {
    font-size: 0.78rem;
    font-weight: 700;
    color: rgba(255,200,170,0.4);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 1.5rem;
}

.details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
}

.detail-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: rgba(18,5,20,0.35);
    border: 1px solid rgba(255,140,50,0.08);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 1.1rem 1.25rem;
    transition: 0.2s;
}
.detail-item:hover {
    background: rgba(232,92,0,0.08);
    border-color: rgba(255,140,50,0.25);
    transform: translateY(-2px);
}

.detail-icon {
    font-size: 1.4rem;
    line-height: 1;
    margin-top: 2px;
    flex-shrink: 0;
}

.detail-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255,200,170,0.4);
    margin-bottom: 4px;
}
.detail-value {
    display: block;
    font-size: 0.92rem;
    color: rgba(255,255,255,0.95);
    font-weight: 500;
    line-height: 1.5;
}

/* DESCRIPTION BLOCK */
.description-block {
    background: rgba(18,5,20,0.4);
    border: 1px solid rgba(255,140,50,0.08);
    border-radius: 16px;
    padding: 1.5rem;
}
.description-text {
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0;
    white-space: pre-line;
}

</style>

<script>
(function() {
    const bg = document.getElementById('blobBg');
    if (!bg) return;
    const positions = [
        [12,8],[25,60],[40,25],[55,80],[68,15],[75,50],[85,35],[90,70],[5,45],[50,5],[30,90],[60,55],[80,20],[15,75],[45,40]
    ];
    positions.forEach(([left, top]) => {
        const s = document.createElement('div');
        s.className = 'sparkle';
        s.style.left = left + '%';
        s.style.top = top + '%';
        s.style.opacity = (0.2 + Math.random() * 0.5).toFixed(2);
        s.style.animation = `float${(Math.floor(Math.random()*5)+1)} ${6+Math.random()*8}s ease-in-out infinite`;
        s.style.animationDelay = (Math.random() * 4).toFixed(1) + 's';
        bg.appendChild(s);
    });
})();
</script>

{% endblock %}