{% extends 'base.html.twig' %}

{% block title %}Modifier le Club{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

<div class="create-page py-4">
    <div class="container-wide">

        <div class="mb-4">
            <a href="{{ path('app_club_index') }}" class="back-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
                Retour aux clubs
            </a>
        </div>

        <div class="form-card">

            <div class="form-left">
                <div class="form-left-inner">
                    <span class="form-badge">Modifier</span>
                    <h1 class="form-title">Modifier le club</h1>
                    <p class="form-subtitle">Mettez à jour les informations de votre club. Les modifications seront visibles immédiatement.</p>
                    <div class="left-info">
                        <div class="info-item">
                            <span class="info-icon">✦</span>
                            <span>Les modifications sont appliquées instantanément</span>
                        </div>
                        <div class="info-item">
                            <span class="info-icon">✦</span>
                            <span>Le logo doit être en format JPG ou PNG</span>
                        </div>
                        <div class="info-item">
                            <span class="info-icon">✦</span>
                            <span>Seul le président peut modifier les infos du club</span>
                        </div>
                    </div>
                </div>
                <div class="deco-circle c1"></div>
                <div class="deco-circle c2"></div>
            </div>

            <div class="form-right">
                {{ include('club/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
            </div>

        </div>

    </div>
</div>

<style>

body {
    min-height: 100vh;
    overflow: hidden;
    background-color: #292222;
    position: relative;
}

/* Background wave image */
body::before {
    content: '';
    position: fixed;

    inset: 0;

    background-image: url('/background/background.jpg');
    background-repeat: no-repeat;
    background-position: center top;
    background-size: cover;

    opacity: 0.4;

    filter: blur(2px);

    z-index: -2;
    pointer-events: none;
}

.create-page { min-height: 100vh; }

.container-wide {
    width: 85%;
    max-width: 1300px;
    margin: -3% auto;
    padding: 0 20px;
}

.back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 7px 16px;
    border-radius: 50px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.05);
    transition: 0.2s ease;
}
.back-btn:hover { color: white; background: rgba(255,255,255,0.1); }

.form-card {
    display: grid;
    grid-template-columns: 340px 1fr;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(16px);
    border-radius: 28px;
    overflow: hidden;
    min-height: 560px;
}

.form-left {
    background: rgba(100,30,220,0.3);
    border-right: 1px solid rgba(255,255,255,0.08);
    padding: 50px 36px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.form-left-inner { position: relative; z-index: 2; }

.deco-circle { position: absolute; border-radius: 50%; pointer-events: none; z-index: 1; }
.c1 { width: 260px; height: 260px; background: rgba(123,47,247,0.15); bottom: -80px; right: -80px; }
.c2 { width: 160px; height: 160px; background: rgba(241,7,163,0.12); top: -50px; left: -50px; }

.form-badge {
    background: linear-gradient(135deg, #f107a3, #7b2ff7);
    color: white;
    padding: 7px 18px;
    border-radius: 50px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    display: inline-block;
}

.form-title {
    color: white;
    font-size: 1.9rem;
    font-weight: 800;
    line-height: 1.25;
    margin-top: 16px;
    margin-bottom: 0;
}

.form-subtitle {
    color: rgba(255,255,255,0.55);
    font-size: 0.88rem;
    line-height: 1.7;
    margin-top: 12px;
}

.left-info { margin-top: 32px; display: flex; flex-direction: column; gap: 14px; }

.info-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
}

.info-icon { color: #a855f7; flex-shrink: 0; margin-top: 1px; }

.form-right {
    padding: 44px 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

</style>

{% endblock %}
