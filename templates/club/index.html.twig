{% extends 'base.html.twig' %}

{% block title %}Clubs ISET Zaghouan{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

<div class="club-page py-4">
    <div class="container">

        <div class="hero-section mb-4">
            <div class="row align-items-center g-3">

                <div class="col-lg-8">
                    <div class="hero-content">
                        <span class="hero-badge">ISET Zaghouan</span>
                        <h1 class="hero-title mt-2">Découvrez les Clubs de l'ISET Zaghouan</h1>
                        <p class="hero-text mt-3">
                            Rejoignez des clubs étudiants, participez à des activités,
                            développez vos compétences et vivez pleinement la vie universitaire.
                        </p>
                       <div class="mt-3 d-flex gap-3 flex-wrap">
    {% if is_granted('ROLE_CHEF_CLUB') %}
        <a href="{{ path('app_club_new') }}" class="hero-btn-primary">
            + Proposer un club
        </a>
    {% endif %}

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_club_pending') }}" class="hero-btn-secondary">
            ⏳ Voir les propositions
        </a>
    {% endif %}
</div>
                    </div>
                </div>

                <div class="col-lg-4 text-center">
                    <div class="iset-logo-box">
                        <img src="{{ asset('images/iset-logo.png') }}"
                             alt="Logo ISET Zaghouan"
                             class="iset-logo">
                    </div>
                </div>

            </div>
        </div>

        <!-- CLUBS GRID -->
        <div class="row g-4">

            {% for club in clubs %}

                <div class="col-md-6 col-lg-4">
                    <div class="club-card h-100">

                        <div class="club-banner">
                            {% if club.logo %}
                                <img src="{{ asset('uploads/logos/' ~ club.logo) }}" alt="{{ club.name }}">
                            {% else %}
                                <div class="default-logo">{{ club.name|slice(0,1)|upper }}</div>
                            {% endif %}
                            <div class="overlay"></div>
                            <div class="club-domain">{{ club.domain }}</div>
                        </div>

                        <div class="club-content">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h3 class="club-title">{{ club.name }}</h3>
                                {% if club.status %}
                                    <span class="status active">Actif</span>
                                {% else %}
                                    <span class="status inactive">Fermé</span>
                                {% endif %}
                            </div>

                            <p class="club-description">
                                {{ club.description|length > 130
                                    ? club.description|slice(0,130) ~ '...'
                                    : club.description }}
                            </p>

                            {% if club.website %}
                                <a href="{{ club.website }}" target="_blank" class="website-link">
                                    Visiter le site
                                </a>
                            {% endif %}

                           <div class="mt-3 d-flex gap-2">

    <a href="{{ path('app_club_show', {'id': club.id}) }}" class="view-btn">
        Voir le club
    </a>

    <a href="#" class="join-btn">
        Rejoindre
    </a>

</div>
                        </div>

                    </div>
                </div>

            {% else %}

                <div class="col-12">
                    <div class="empty-box text-center">
                        <h2 class="fw-bold text-white mb-3">Aucun club disponible</h2>
                        <p class="text-light opacity-75 mb-0">Les clubs apparaîtront ici une fois ajoutés.</p>
                    </div>
                </div>

            {% endfor %}

        </div>

    </div>
</div>

<style>

body {
    min-height: 100vh;
    background-color: #292222;
    position: relative;
}

::-webkit-scrollbar {
    width: 10px;
}

::-webkit-scrollbar-track {
    background: transparent;
}
::-webkit-scrollbar-thumb {
    background: rgba(241, 234, 234, 0.2);
    border-radius: 20px;
}



/* Background wave image */
body::before {
    content: '';
    position: fixed;

    inset: 0;

    background-image: url('/background/background.jpg');
    background-repeat: no-repeat;
    background-position: center top;
    background-size: cover;

    opacity: 0.4;

    filter: blur(2px);

    z-index: -2;
    pointer-events: none;
}

.club-page { min-height: 100vh; }

.hero-section {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(14px);
    border-radius: 24px;
    padding: 32px 40px;
    position: relative;
    overflow: hidden;
}

.hero-section::before {
    content: '';
    position: absolute;
    width: 240px;
    height: 240px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
    top: -100px;
    right: -80px;
    pointer-events: none;
}

.hero-badge {
    background: linear-gradient(135deg, #7b2ff7, #f107a3);
    color: white;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
}

.hero-title {
    color: white;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
}

.hero-text {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 0;
}

.hero-btn-primary {
    display: inline-block;
    padding: 10px 22px;
    border-radius: 50px;
    background: linear-gradient(135deg, #7b2ff7, #f107a3);
    color: white;
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    transition: 0.2s ease;
}
.hero-btn-primary:hover { opacity: 0.88; color: white; transform: scale(1.02); }

.iset-logo-box {
    width: 180px;
    height: 180px;
    margin: auto;
    background: rgba(255,255,255,0.08);
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    transition: 0.3s ease;
}
.iset-logo-box:hover { transform: scale(1.03); }
.iset-logo { width: 100%; height: 100%; object-fit: contain; }

.club-card {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    overflow: hidden;
    transition: 0.3s ease;
}
.club-card:hover { transform: translateY(-6px); border-color: rgba(168,85,247,0.4); }

.club-banner {
    height: 160px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #7b2ff7, #f107a3);
}
.club-banner img { width: 100%; height: 100%; object-fit: cover; }

.overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55), rgba(0,0,0,0.05));
}

.default-logo {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 4rem; font-weight: bold; color: white;
}

.club-domain {
    position: absolute;
    bottom: 12px; left: 16px;
    color: rgba(255,255,255,0.85);
    font-weight: 600; font-size: 0.78rem;
    letter-spacing: 1px; z-index: 2;
    text-transform: uppercase;
}

.club-content { padding: 1.25rem; color: white; }
.club-title { font-weight: 700; font-size: 1rem; margin: 0; }

.club-description {
    color: rgba(255,255,255,0.7);
    line-height: 1.6; font-size: 0.88rem;
    min-height: 70px;
}
.hero-btn-secondary {
    display: inline-block;
    padding: 10px 22px;
    border-radius: 50px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.85);
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    transition: 0.2s ease;
}
.hero-btn-secondary:hover { background: rgba(255,255,255,0.14); color: white; }

.status { padding: 4px 11px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; white-space: nowrap; }
.status.active { background: rgba(25,135,84,0.2); color: #4ade80; }
.status.inactive { background: rgba(220,53,69,0.2); color: #ff6b81; }

.website-link { color: #d8b4fe; text-decoration: none; font-size: 0.85rem; font-weight: 500; }
.website-link:hover { color: white; }

.view-btn {
    flex: 1;
    display: block; text-align: center;
    padding: 10px; border-radius: 12px;
    text-decoration: none; font-weight: 700;
    font-size: 0.85rem; color: white;
    background: linear-gradient(135deg, #7b2ff7, #f107a3);
    transition: 0.2s ease;
}
.view-btn:hover { opacity: 0.88; color: white; }
.join-btn {
    display: flex;
    align-items: center;
    justify-content: center;

    padding: 10px 16px;

    border-radius: 12px;

    text-decoration: none;

    font-weight: 700;
    font-size: 0.85rem;

    color: white;

    background: rgba(255,255,255,0.08);

    border: 1px solid rgba(255,255,255,0.12);

    transition: 0.2s ease;

    white-space: nowrap;
}

.join-btn:hover {
    background: rgba(168,85,247,0.2);
    color: white;
    border-color: #a855f7;
}

.empty-box {
    padding: 60px 20px; border-radius: 20px;
    background: rgba(255,255,255,0.07);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.08);
}

</style>

{% endblock %}
