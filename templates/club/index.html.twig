{% extends 'base.html.twig' %}

{% block title %}Clubs ISET Zaghouan{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

{# ── Animated blob background ── #}
<div class="blob-bg" id="blobBg" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>
</div>

<div class="club-page py-4">
    <div class="container">

        <!-- FLASH MESSAGES -->
        {% for flash in app.flashes('success') %}
            <div class="alert-flash success mb-2">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('warning') %}
            <div class="alert-flash warning mb-2">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('error') %}
            <div class="alert-flash error mb-2">{{ flash }}</div>
        {% endfor %}

        <!-- HERO -->
        <div class="hero-section mb-4">
            <div class="row align-items-center g-3">

                <div class="col-lg-8">
                    <div class="hero-content">
                        <span class="hero-badge">ISET Zaghouan</span>
                        <h1 class="hero-title mt-2">Découvrez les Clubs de l'ISET Zaghouan</h1>
                        <p class="hero-text mt-3">
                            Rejoignez des clubs étudiants, participez à des activités,
                            développez vos compétences et vivez pleinement la vie universitaire.
                        </p>
                        <div class="mt-3 d-flex gap-3 flex-wrap">

                            <a href="{{ path('app_club_new') }}" class="hero-btn-primary">
                                + Proposer un club
                            </a>

                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_club_pending') }}" class="hero-btn-secondary">
                                    ⏳ Voir les propositions
                                </a>
                            {% endif %}

                        </div>
                    </div>
                </div>

                <div class="col-lg-4 text-center">
                    <div class="iset-logo-box">
                        <img src="{{ asset('images/iset-logo.png') }}"
                             alt="Logo ISET Zaghouan"
                             class="iset-logo">
                    </div>
                </div>

            </div>
        </div>

        <!-- CLUBS GRID -->
        <div class="row g-4">

            {% for club in clubs %}

                <div class="col-md-4 col-lg-3">
                    <div class="club-card h-100">

                        <div class="club-banner">
                            {% if club.logo %}
                                <img src="{{ asset('uploads/logos/' ~ club.logo) }}" alt="{{ club.name }}">
                            {% else %}
                                <div class="default-logo">{{ club.name|slice(0,1)|upper }}</div>
                            {% endif %}
                            <div class="overlay"></div>
                            <div class="club-domain">{{ club.domain }}</div>
                        </div>

                        <div class="club-content">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h3 class="club-title">{{ club.name }}</h3>
                                    <span class="status active">{{ club.status|title }}</span>
                            </div>

                            <p class="club-description">
                                {{ club.description|length > 130
                                    ? club.description|slice(0,130) ~ '...'
                                    : club.description }}
                            </p>

                            {% if club.website %}
                                <a href="//{{ club.website }}" target="_blank" class="website-link">
                                    Visiter le site
                                </a>
                            {% endif %}

                            <div class="mt-3 d-flex gap-2">

                                <a href="{{ path('app_club_show', {'id': club.id}) }}" class="view-btn">
                                    Voir le club
                                </a>

                                {% if app.user %}
                                    {% set isMember = false %}
                                    {% for member in club.clubMembers %}
                                        {% if member.user == app.user %}
                                            {% set isMember = true %}
                                        {% endif %}
                                    {% endfor %}

                                    {% if isMember %}
                                        <form method="POST" action="{{ path('app_club_leave', {'id': club.id}) }}">
                                            <button type="submit" class="leave-btn">Quitter</button>
                                        </form>
                                    {% else %}
                                        <a href="{{ path('app_club_join', {'id': club.id}) }}" class="join-btn">
                                            Rejoindre
                                        </a>
                                    {% endif %}
                                {% endif %}

                            </div>
                        </div>

                    </div>
                </div>

            {% else %}

                <div class="col-12">
                    <div class="empty-box text-center">
                        <h2 class="fw-bold text-white mb-3">Aucun club disponible</h2>
                        <p class="text-light opacity-75 mb-0">Les clubs apparaîtront ici une fois ajoutés.</p>
                    </div>
                </div>

            {% endfor %}

        </div>

    </div>
</div>

<style>

/* ── Animated blob background ── */
.blob-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background: radial-gradient(ellipse at 70% 40%, #e84c0e 0%, #b81c05 35%, #7a0a0e 65%, #2d0520 100%);
}

.blob {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: screen;
    filter: blur(2px);
}

.blob-1 {
    width: 340px; height: 340px;
    background: radial-gradient(circle at 40% 35%, #ffaa00, #e85c00 55%, transparent 80%);
    top: -60px; right: 100px;
    animation: float1 9s ease-in-out infinite;
}
.blob-2 {
    width: 180px; height: 180px;
    background: radial-gradient(circle at 45% 40%, #ffd060, #ff8800 60%, transparent 80%);
    top: 20px; right: 330px;
    animation: float2 11s ease-in-out infinite;
}
.blob-3 {
    width: 420px; height: 360px;
    background: radial-gradient(circle at 50% 45%, #ff6a00 0%, #dd2200 50%, transparent 75%);
    bottom: -100px; right: -40px;
    animation: float3 13s ease-in-out infinite;
}
.blob-4 {
    width: 260px; height: 200px;
    background: radial-gradient(circle at 50% 50%, #ff4500 0%, #9e0a00 55%, transparent 80%);
    bottom: 20px; left: 80px;
    animation: float4 10s ease-in-out infinite;
}
.blob-5 {
    width: 90px; height: 90px;
    background: radial-gradient(circle at 45% 40%, #ffc040, #ff7800 60%, transparent 80%);
    top: 130px; right: 260px;
    animation: float5 7s ease-in-out infinite;
}

.sparkle {
    position: absolute;
    width: 3px; height: 3px;
    background: rgba(255,255,255,0.55);
    border-radius: 50%;
}

@keyframes float1 {
    0%,100% { transform: translate(0,0) scale(1); }
    33% { transform: translate(-18px, 22px) scale(1.04); }
    66% { transform: translate(12px, -14px) scale(0.97); }
}
@keyframes float2 {
    0%,100% { transform: translate(0,0) scale(1); }
    40% { transform: translate(20px, 18px) scale(1.06); }
    70% { transform: translate(-10px, -8px) scale(0.95); }
}
@keyframes float3 {
    0%,100% { transform: translate(0,0) scale(1); }
    30% { transform: translate(-25px, -20px) scale(1.03); }
    60% { transform: translate(15px, 12px) scale(0.98); }
}
@keyframes float4 {
    0%,100% { transform: translate(0,0) scale(1); }
    45% { transform: translate(22px, -18px) scale(1.05); }
    75% { transform: translate(-12px, 10px) scale(0.96); }
}
@keyframes float5 {
    0%,100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(-14px, 20px) scale(1.1); }
}

/* ── Rest of styles (unchanged) ── */

body {
    min-height: 100vh;
}

::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(241,234,234,0.2); border-radius: 20px; }

.club-page { min-height: 100vh; }

.club-page .container {
    max-width: 1480px;
}

/* ── Hero section ── */
.hero-section {
    background: rgba(18, 5, 20, 0.55);
    border: 1px solid rgba(255, 140, 50, 0.15);
    backdrop-filter: blur(18px);
    border-radius: 20px;
    padding: 28px 32px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.06);
}
.hero-section::before {
    content: '';
    position: absolute;
    width: 240px; height: 240px;
    background: radial-gradient(circle, rgba(232,76,14,0.12), transparent 70%);
    border-radius: 50%;
    top: -100px; right: -80px;
    pointer-events: none;
}

.hero-badge {
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    box-shadow: 0 2px 10px rgba(232,92,0,0.35);
}

.hero-title {
    color: white;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
}

.hero-text {
    color: rgba(255,200,170,0.7);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 0;
}

.hero-btn-primary {
    display: inline-block;
    padding: 10px 22px;
    border-radius: 50px;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white;
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    transition: 0.2s ease;
    box-shadow: 0 4px 16px rgba(232,92,0,0.35);
}
.hero-btn-primary:hover { opacity: 0.92; color: white; transform: scale(1.02); box-shadow: 0 6px 24px rgba(232,92,0,0.5); }

.hero-btn-secondary {
    display: inline-block;
    padding: 10px 22px;
    border-radius: 50px;
    background: rgba(232,92,0,0.1);
    border: 1px solid rgba(255,140,50,0.25);
    color: rgba(255,220,190,0.9);
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    transition: 0.2s ease;
}
.hero-btn-secondary:hover { background: rgba(232,92,0,0.2); color: white; }

.iset-logo-box {
    width: 180px; height: 180px;
    margin: auto;
    background: rgba(18,5,20,0.5);
    border-radius: 24px;
    display: flex; align-items: center; justify-content: center;
    padding: 10px;
    border: 1px solid rgba(255,140,50,0.15);
    backdrop-filter: blur(10px);
    transition: 0.3s ease;
}
.iset-logo-box:hover { transform: scale(1.03); border-color: rgba(255,140,50,0.3); }
.iset-logo { width: 100%; height: 100%; object-fit: contain; }

/* ── Club card ── */
.club-card {
    background: rgba(18, 5, 20, 0.5);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 140, 50, 0.1);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}
.club-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 140, 50, 0.3);
    box-shadow: 0 12px 40px rgba(232,92,0,0.15);
}

/* ── Club banner ── */
.club-banner {
    height: 130px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #e85c00, #b81c05, #7a0a0e);
}
.club-banner img { width: 100%; height: 100%; object-fit: cover; }

.overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(18,5,20,0.75) 0%, rgba(0,0,0,0.15) 60%, transparent 100%);
}

.default-logo {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem; font-weight: bold;
    color: rgba(255,255,255,0.9);
    text-shadow: 0 2px 20px rgba(0,0,0,0.4);
    background: linear-gradient(135deg, rgba(232,92,0,0.3), rgba(122,10,14,0.3));
}

.club-domain {
    position: absolute;
    top: 10px; right: 10px;
    color: rgba(255,220,190,0.95);
    font-weight: 700; font-size: 0.65rem;
    letter-spacing: 1.2px; z-index: 2;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 8px;
    background: rgba(18,5,20,0.6);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,140,50,0.15);
}

/* ── Club content ── */
.club-content {
    padding: 1rem;
    color: rgba(255,255,255,0.92);
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.15));
}

.club-title {
    font-weight: 700;
    font-size: 0.95rem;
    margin: 0;
    color: white;
}

.club-description {
    color: rgba(255,200,170,0.7);
    line-height: 1.6;
    font-size: 0.82rem;
    min-height: 52px;
}

.status {
    padding: 3px 10px;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 700;
    white-space: nowrap;
    letter-spacing: 0.3px;
    text-transform: uppercase;
}
.status.active   { background: rgba(232,92,0,0.15);  color: #ff9944; border: 1px solid rgba(255,153,68,0.25); }
.status.inactive { background: rgba(220,53,69,0.12); color: #ff6b81; border: 1px solid rgba(255,107,129,0.2); }
.status.pending  { background: rgba(234,179,8,0.12); color: #facc15; border: 1px solid rgba(250,204,21,0.2); }

.website-link {
    color: rgba(255,180,120,0.8);
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 500;
    transition: 0.2s ease;
}
.website-link:hover { color: #ff9944; }

/* ── Buttons ── */
.view-btn {
    flex: 1;
    display: block; text-align: center;
    padding: 10px 14px; border-radius: 12px;
    text-decoration: none; font-weight: 700;
    font-size: 0.85rem; color: white;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    transition: 0.25s ease;
    box-shadow: 0 4px 14px rgba(232,92,0,0.3);
}
.view-btn:hover { opacity: 0.92; color: white; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(232,92,0,0.45); }

.join-btn {
    flex: 1;
    display: block; text-align: center;
    padding: 10px 14px; border-radius: 12px;
    font-weight: 700; font-size: 0.85rem;
    color: white; cursor: pointer;
    background: rgba(232,92,0,0.12);
    border: 1px solid rgba(255,140,50,0.3);
    transition: 0.25s ease;
    width: 100%;
    text-decoration: none;
    backdrop-filter: blur(4px);
}
.join-btn:hover { background: rgba(232,92,0,0.25); }

.leave-btn {
    flex: 1;
    display: block; text-align: center;
    padding: 10px 14px; border-radius: 12px;
    font-weight: 700; font-size: 0.85rem;
    color: #ff6b81; cursor: pointer;
    background: rgba(220,53,69,0.1);
    border: 1px solid rgba(255,107,129,0.2);
    transition: 0.25s ease;
    width: 100%;
    backdrop-filter: blur(4px);
}
.leave-btn:hover { background: rgba(220,53,69,0.2); color: #ff8a9e; }

.edit-btn {
    display: flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: 12px;
    background: rgba(232,92,0,0.08);
    border: 1px solid rgba(255,140,50,0.15);
    color: rgba(255,200,170,0.7);
    text-decoration: none; flex-shrink: 0;
    transition: 0.2s ease;
}
.edit-btn:hover { background: rgba(232,92,0,0.18); color: white; border-color: rgba(255,140,50,0.4); }

.empty-box {
    padding: 60px 20px; border-radius: 20px;
    background: rgba(18,5,20,0.45);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,140,50,0.08);
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
}

/* ── Alert flashes ── */
.alert-flash {
    padding: 12px 20px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.9rem;
    backdrop-filter: blur(8px);
}
.alert-flash.success { background: rgba(232,92,0,0.12);  border: 1px solid rgba(255,153,68,0.25);  color: #ff9944; }
.alert-flash.warning { background: rgba(220,53,69,0.1);  border: 1px solid rgba(255,107,129,0.2); color: #ff6b81; }
.alert-flash.error   { background: rgba(220,53,69,0.15);  border: 1px solid rgba(255,107,129,0.3); color: #ff8a9e; }

</style>

<script>
(function() {
    const bg = document.getElementById('blobBg');
    const positions = [
        [12,8],[25,60],[40,25],[55,80],[68,15],[75,50],[85,35],[90,70],[5,45],[50,5],[30,90],[60,55],[80,20],[15,75],[45,40]
    ];
    positions.forEach(([left, top]) => {
        const s = document.createElement('div');
        s.className = 'sparkle';
        s.style.left = left + '%';
        s.style.top = top + '%';
        s.style.opacity = (0.2 + Math.random() * 0.5).toFixed(2);
        s.style.animation = `float${(Math.floor(Math.random()*5)+1)} ${6+Math.random()*8}s ease-in-out infinite`;
        s.style.animationDelay = (Math.random() * 4).toFixed(1) + 's';
        bg.appendChild(s);
    });
})();
</script>

{% endblock %}
