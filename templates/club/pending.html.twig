{% extends 'base.html.twig' %}
{% block title %}Clubs en attente{% endblock %}

{% block body %}
{% include 'navbar/navbar.html.twig' %}

{# ── Animated blob background ── #}
<div class="blob-bg" id="blobBg" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>
</div>

<div class="club-page py-4">
    <div class="container">

        <div class="mb-4">
            <h1 class="text-white fw-bold">Clubs en attente de validation</h1>
            <p class="text-white-50">{{ clubs|length }} proposition(s) en attente</p>
        </div>

        {% for flash in app.flashes('success') %}
            <div class="alert-flash success mb-3">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('warning') %}
            <div class="alert-flash warning mb-3">{{ flash }}</div>
        {% endfor %}

        {% for club in clubs %}
        <div class="pending-card mb-3">
            <div class="d-flex align-items-center gap-4 flex-wrap">

                <div class="pending-logo">
                    {% if club.logo %}
                        <img src="{{ asset('uploads/logos/' ~ club.logo) }}" alt="{{ club.name }}">
                    {% else %}
                        <div class="logo-initial-sm">{{ club.name|slice(0,1)|upper }}</div>
                    {% endif %}
                </div>

                <div class="flex-grow-1">
                    <div class="d-flex gap-2 mb-1">
                        <span class="domain-badge">{{ club.domain }}</span>
                    </div>
                    <h3 class="text-white fw-bold mb-1">{{ club.name }}</h3>
                    <p class="text-white-50 mb-1" style="font-size:0.9rem">{{ club.description }}</p>
                    {% if club.website %}
                        <a href="{{ club.website }}" target="_blank" class="website-link">
                            🌐 {{ club.website }}
                        </a>
                    {% endif %}
                    <p class="text-white-50 mt-1" style="font-size:0.8rem">
                        Proposé le {{ club.createdAt ? club.createdAt|date('d/m/Y à H:i') : '—' }}
                    </p>
                </div>

                <div class="d-flex gap-2 flex-shrink-0">
                    <form method="POST" action="{{ path('app_club_review', {'id': club.id}) }}">
                        <input type="hidden" name="action" value="approve">
                        <button type="submit" class="review-btn approve-btn">✓ Approuver</button>
                    </form>
                    <form method="POST" action="{{ path('app_club_review', {'id': club.id}) }}">
                        <input type="hidden" name="action" value="reject">
                        <button type="submit" class="review-btn reject-btn">✗ Rejeter</button>
                    </form>
                </div>

            </div>
        </div>
        {% else %}
            <div class="empty-box text-center">
                <p class="text-white fw-bold mb-0">Aucune proposition en attente.</p>
            </div>
        {% endfor %}

    </div>
</div>

<style>

/* ── Animated blob background ── */
.blob-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background: radial-gradient(ellipse at 70% 40%, #e84c0e 0%, #b81c05 35%, #7a0a0e 65%, #2d0520 100%);
}

.blob {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: screen;
    filter: blur(2px);
}

.blob-1 {
    width: 340px; height: 340px;
    background: radial-gradient(circle at 40% 35%, #ffaa00, #e85c00 55%, transparent 80%);
    top: -60px; right: 100px;
    animation: float1 9s ease-in-out infinite;
}
.blob-2 {
    width: 180px; height: 180px;
    background: radial-gradient(circle at 45% 40%, #ffd060, #ff8800 60%, transparent 80%);
    top: 20px; right: 330px;
    animation: float2 11s ease-in-out infinite;
}
.blob-3 {
    width: 420px; height: 360px;
    background: radial-gradient(circle at 50% 45%, #ff6a00 0%, #dd2200 50%, transparent 75%);
    bottom: -100px; right: -40px;
    animation: float3 13s ease-in-out infinite;
}
.blob-4 {
    width: 260px; height: 200px;
    background: radial-gradient(circle at 50% 50%, #ff4500 0%, #9e0a00 55%, transparent 80%);
    bottom: 20px; left: 80px;
    animation: float4 10s ease-in-out infinite;
}
.blob-5 {
    width: 90px; height: 90px;
    background: radial-gradient(circle at 45% 40%, #ffc040, #ff7800 60%, transparent 80%);
    top: 130px; right: 260px;
    animation: float5 7s ease-in-out infinite;
}

.sparkle {
    position: absolute;
    width: 3px; height: 3px;
    background: rgba(255,255,255,0.55);
    border-radius: 50%;
}

@keyframes float1 {
    0%,100% { transform: translate(0,0) scale(1); }
    33% { transform: translate(-18px, 22px) scale(1.04); }
    66% { transform: translate(12px, -14px) scale(0.97); }
}
@keyframes float2 {
    0%,100% { transform: translate(0,0) scale(1); }
    40% { transform: translate(20px, 18px) scale(1.06); }
    70% { transform: translate(-10px, -8px) scale(0.95); }
}
@keyframes float3 {
    0%,100% { transform: translate(0,0) scale(1); }
    30% { transform: translate(-25px, -20px) scale(1.03); }
    60% { transform: translate(15px, 12px) scale(0.98); }
}
@keyframes float4 {
    0%,100% { transform: translate(0,0) scale(1); }
    45% { transform: translate(22px, -18px) scale(1.05); }
    75% { transform: translate(-12px, 10px) scale(0.96); }
}
@keyframes float5 {
    0%,100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(-14px, 20px) scale(1.1); }
}

body {
    min-height: 100vh;
}

::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,200,170,0.2); border-radius: 20px; }

.club-page .container {
    max-width: 1480px;
}
.club-page { min-height: 100vh; }

.alert-flash {
    padding: 12px 20px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.9rem;
    backdrop-filter: blur(8px);
}
.alert-flash.success {
    background: rgba(232,92,0,0.12);
    border: 1px solid rgba(255,153,68,0.25);
    color: #ff9944;
}
.alert-flash.warning {
    background: rgba(220,53,69,0.1);
    border: 1px solid rgba(255,107,129,0.2);
    color: #ff6b81;
}

.pending-card {
    background: rgba(18, 5, 20, 0.5);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,140,50,0.1);
    border-radius: 20px;
    padding: 1.5rem 2rem;
    transition: 0.2s;
}
.pending-card:hover { border-color: rgba(255,140,50,0.3); }

.pending-logo {
    width: 80px; height: 80px;
    border-radius: 16px;
    background: rgba(18,5,20,0.5);
    border: 1px solid rgba(255,140,50,0.1);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.pending-logo img { width: 100%; height: 100%; object-fit: contain; padding: 6px; }
.logo-initial-sm {
    font-size: 2rem; font-weight: 800; color: white;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
}

.domain-badge {
    background: rgba(232,92,0,0.15);
    border: 1px solid rgba(255,140,50,0.3);
    color: #ff9944;
    padding: 3px 12px;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
}

.website-link { color: rgba(255,180,120,0.8); text-decoration: none; font-size: 0.85rem; }
.website-link:hover { color: #ff9944; }

.review-btn {
    padding: 9px 20px;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: 0.2s;
}
.approve-btn {
    background: rgba(232,92,0,0.12);
    border: 1px solid rgba(255,153,68,0.3);
    color: #ff9944;
}
.approve-btn:hover { background: rgba(232,92,0,0.25); color: white; }

.reject-btn {
    background: rgba(220,53,69,0.1);
    border: 1px solid rgba(255,107,129,0.2);
    color: #ff6b81;
}
.reject-btn:hover { background: rgba(220,53,69,0.2); color: #ff8a9e; }

.empty-box {
    padding: 60px 20px;
    border-radius: 20px;
    background: rgba(18,5,20,0.45);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,140,50,0.08);
}
</style>

<script>
(function() {
    const bg = document.getElementById('blobBg');
    if (!bg) return;
    const positions = [
        [12,8],[25,60],[40,25],[55,80],[68,15],[75,50],[85,35],[90,70],[5,45],[50,5],[30,90],[60,55],[80,20],[15,75],[45,40]
    ];
    positions.forEach(([left, top]) => {
        const s = document.createElement('div');
        s.className = 'sparkle';
        s.style.left = left + '%';
        s.style.top = top + '%';
        s.style.opacity = (0.2 + Math.random() * 0.5).toFixed(2);
        s.style.animation = `float${(Math.floor(Math.random()*5)+1)} ${6+Math.random()*8}s ease-in-out infinite`;
        s.style.animationDelay = (Math.random() * 4).toFixed(1) + 's';
        bg.appendChild(s);
    });
})();
</script>

{% endblock %}