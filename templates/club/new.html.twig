{% extends 'base.html.twig' %}

{% block title %}Créer un Club{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

<div class="create-page py-4">
    <div class="container-wide">

        <div class="mb-4">
            <a href="{{ path('app_club_index') }}" class="back-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
                Retour aux clubs
            </a>
        </div>

        <div class="form-card">

            <!-- LEFT SIDE: title/info -->
            <div class="form-left">
                <div class="form-left-inner">
                    <span class="form-badge">Nouveau club</span>
                    <h1 class="form-title">Créer un nouveau club</h1>
                    <p class="form-subtitle">Remplissez les informations pour proposer votre club à l'administration ISET Zaghouan.</p>
                    <div class="left-info">
                        <div class="info-item">
                            <span class="info-icon">✦</span>
                            <span>Votre club sera examiné par l'administration</span>
                        </div>
                        <div class="info-item">
                            <span class="info-icon">✦</span>
                            <span>Vous recevrez une notification après validation</span>
                        </div>
                        <div class="info-item">
                            <span class="info-icon">✦</span>
                            <span>Vous deviendrez automatiquement président</span>
                        </div>
                    </div>
                </div>
                <div class="deco-circle c1"></div>
                <div class="deco-circle c2"></div>
            </div>

            <!-- RIGHT SIDE: the actual form in 2 columns -->
            <div class="form-right">
                {{ include('club/_form.html.twig') }}
            </div>

        </div>

    </div>
</div>

<style>

body {
    min-height: 100vh;
    overflow: hidden;
    background-color: #050505;
    position: relative;
}

/* Background wave image */
body::before {
    content: '';
    position: fixed;

    inset: 0;

    background-image: url('/background/background.jpg');
    background-repeat: no-repeat;
    background-position: center top;
    background-size: cover;

    opacity: 0.4;

    filter: blur(2px);

    z-index: -2;
    pointer-events: none;
}

.create-page {
    height: 100vh;
}

.container-wide {
    width: 90%;
    margin: -2% auto;
    min-height: 100%;
}

.back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 7px 16px;
    border-radius: 50px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.05);
    transition: 0.2s ease;
}

.back-btn:hover {
    color: white;
    background: rgba(255,255,255,0.1);
}

/* CARD = side by side */
.form-card {
    display: grid;
    grid-template-columns: 340px 1fr;
    background: rgba(59, 55, 55, 0.574);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(16px);
    border-radius: 28px;
    height: 73vh;

}

/* LEFT PANEL */
.form-left {
    background: rgba(100,30,220,0.3);
    border-radius: 28px;
    border-right: 1px solid rgba(255,255,255,0.08);
    padding: 50px 36px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 73vh;
}

.form-left-inner {
    position: relative;
    z-index: 2;
}

.deco-circle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
}
.c1 { width: 260px; height: 260px; background: rgba(241,7,163,0.12); bottom: -80px; right: -80px; }
.c2 { width: 160px; height: 160px; background: rgba(123,47,247,0.18); top: -50px; left: -50px; }

.form-badge {
    background: linear-gradient(135deg, #7b2ff7, #f107a3);
    color: white;
    padding: 7px 18px;
    border-radius: 50px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    display: inline-block;
}

.form-title {
    color: white;
    font-size: 1.9rem;
    font-weight: 800;
    line-height: 1.25;
    margin-top: 16px;
    margin-bottom: 0;
}

.form-subtitle {
    color: rgba(255,255,255,0.55);
    font-size: 0.88rem;
    line-height: 1.7;
    margin-top: 12px;
}

.left-info {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.info-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
}

.info-icon {
    color: #a855f7;
    flex-shrink: 0;
    margin-top: 1px;
}

/* RIGHT PANEL */
.form-right {
    padding: 44px 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

/* Make the form inside a 2-column grid */
.form-right form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px 24px;
}

/* textarea rows and last rows go full width */
.form-right form > div:has(textarea),
.form-right form > div:has(button),
.form-right form > div:has(input[type="submit"]),
.form-right form > div:last-child {
    grid-column: 1 / -1;
}

/* LABELS */
.form-right label {
    display: block;
    color: rgba(255,255,255,0.65);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.7px;
    margin-bottom: 6px;
    text-transform: uppercase;
}

/* INPUTS */
.form-right input[type="text"],
.form-right input[type="url"],
.form-right input[type="datetime-local"],
.form-right textarea,
.form-right select {
    width: 100%;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 11px 15px;
    color: white;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    -webkit-appearance: none;
    appearance: none;
}

.form-right input::placeholder,
.form-right textarea::placeholder {
    color: rgba(255,255,255,0.2);
}

.form-right input:focus,
.form-right textarea:focus,
.form-right select:focus {
    border-color: #a855f7;
    background: rgba(168,85,247,0.1);
}

.form-right select option {
    background: #240046;
    color: white;
}

.form-right textarea {
    min-height: 110px;
    resize: vertical;
}

/* SUBMIT BUTTON */
.form-right button[type="submit"],
.form-right input[type="submit"] {
    width: 100%;
    padding: 13px;
    border: none;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 700;
    color: white;
    background: linear-gradient(135deg, #7b2ff7, #f107a3);
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    letter-spacing: 0.5px;
    margin-top: 4px;
}

.form-right button[type="submit"]:hover,
.form-right input[type="submit"]:hover {
    opacity: 0.88;
    transform: scale(1.01);
}

/* ERRORS */
.form-right .invalid-feedback,
.form-right .form-error {
    color: #ff6b81;
    font-size: 0.78rem;
    margin-top: 4px;
}

</style>

{% endblock %}
