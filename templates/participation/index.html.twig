{% extends 'base.html.twig' %}

{% block title %}Mes participations{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

<div class="blob-bg" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>
</div>

<div class="page py-4">
    <div class="container">

        <div class="hero-section mb-4">
            <div class="hero-content">
                <span class="hero-badge">ISET Zaghouan</span>
                <h1 class="hero-title mt-2">Mes participations</h1>
                <p class="hero-text mt-3">Tous les événements auxquels vous êtes inscrit.</p>
            </div>
        </div>

        {% for flash in app.flashes('success') %}
            <div class="alert-flash success mb-3">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('error') %}
            <div class="alert-flash error mb-3">{{ flash }}</div>
        {% endfor %}

        <div class="participations-list">
            {% for participation in participations %}
                <div class="participation-card">
                    <div class="pc-left">
                        <div class="pc-date-box">
                            <div class="pc-day">{{ participation.evenement.dateDebut ? participation.evenement.dateDebut|date('d') : '—' }}</div>
                            <div class="pc-month">{{ participation.evenement.dateDebut ? participation.evenement.dateDebut|date('M') : '' }}</div>
                        </div>
                    </div>
                    <div class="pc-body">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <div>
                                <h3 class="pc-title">{{ participation.evenement.nomEvenement }}</h3>
                                <div class="pc-meta">
                                    {% if participation.evenement.club %}
                                        <span class="pc-club">{{ participation.evenement.club.name }}</span>
                                    {% endif %}
                                    <span>{{ participation.evenement.lieu }}</span>
                                    <span>{{ participation.evenement.dateDebut ? participation.evenement.dateDebut|date('H:i') : '—' }} — {{ participation.evenement.dateFin ? participation.evenement.dateFin|date('H:i') : '—' }}</span>
                                </div>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-1">
                                <span class="pc-status {{ participation.presenceStatus }}">
                                    {{ participation.presenceStatus == 'present' ? 'Présent' : participation.presenceStatus == 'absent' ? 'Absent' : 'Inscrit' }}
                                </span>
                                {% if participation.evenement.dateDebut > date() %}
                                    <span class="pc-upcoming-badge">À venir</span>
                                {% elseif participation.evenement.dateFin < date() %}
                                    <span class="pc-past-badge">Passé</span>
                                {% else %}
                                    <span class="pc-now-badge">En cours</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="pc-footer mt-2">
                            <a href="{{ path('app_evenement_show', {'id': participation.evenement.id}) }}" class="pc-btn">
                                Voir l'événement →
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="empty-box text-center">
                    <h2 class="fw-bold text-white mb-3">Aucune participation</h2>
                    <p class="text-light opacity-75">Vous n'êtes inscrit à aucun événement pour le moment.</p>
                    <a href="{{ path('app_evenement_index') }}" class="hero-btn-primary mt-3 d-inline-block">Découvrir les événements</a>
                </div>
            {% endfor %}
        </div>

    </div>
</div>

<style>

.blob-bg {
    position: fixed; inset: 0; z-index: -1; overflow: hidden;
    background: radial-gradient(ellipse at 70% 40%, #e84c0e 0%, #b81c05 35%, #7a0a0e 65%, #2d0520 100%);
}
.blob { position: absolute; border-radius: 50%; mix-blend-mode: screen; filter: blur(2px); }
.blob-1 { width: 340px; height: 340px; background: radial-gradient(circle at 40% 35%, #ffaa00, #e85c00 55%, transparent 80%); top: -60px; right: 100px; animation: float1 9s ease-in-out infinite; }
.blob-2 { width: 180px; height: 180px; background: radial-gradient(circle at 45% 40%, #ffd060, #ff8800 60%, transparent 80%); top: 20px; right: 330px; animation: float2 11s ease-in-out infinite; }
.blob-3 { width: 420px; height: 360px; background: radial-gradient(circle at 50% 45%, #ff6a00 0%, #dd2200 50%, transparent 75%); bottom: -100px; right: -40px; animation: float3 13s ease-in-out infinite; }
.blob-4 { width: 260px; height: 200px; background: radial-gradient(circle at 50% 50%, #ff4500 0%, #9e0a00 55%, transparent 80%); bottom: 20px; left: 80px; animation: float4 10s ease-in-out infinite; }
.blob-5 { width: 90px; height: 90px; background: radial-gradient(circle at 45% 40%, #ffc040, #ff7800 60%, transparent 80%); top: 130px; right: 260px; animation: float5 7s ease-in-out infinite; }
@keyframes float1 { 0%,100% { transform: translate(0,0) scale(1); } 33% { transform: translate(-18px, 22px) scale(1.04); } 66% { transform: translate(12px, -14px) scale(0.97); } }
@keyframes float2 { 0%,100% { transform: translate(0,0) scale(1); } 40% { transform: translate(20px, 18px) scale(1.06); } 70% { transform: translate(-10px, -8px) scale(0.95); } }
@keyframes float3 { 0%,100% { transform: translate(0,0) scale(1); } 30% { transform: translate(-25px, -20px) scale(1.03); } 60% { transform: translate(15px, 12px) scale(0.98); } }
@keyframes float4 { 0%,100% { transform: translate(0,0) scale(1); } 45% { transform: translate(22px, -18px) scale(1.05); } 75% { transform: translate(-12px, 10px) scale(0.96); } }
@keyframes float5 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-14px, 20px) scale(1.1); } }

body { min-height: 100vh; }
::selection { background: rgba(232,92,0,0.3); }
::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,200,170,0.2); border-radius: 20px; }

.page { min-height: 100vh; }
.page .container { max-width: 1480px; }

.hero-section {
    background: rgba(18,5,20,0.55);
    border: 1px solid rgba(255,140,50,0.15);
    backdrop-filter: blur(18px);
    border-radius: 20px;
    padding: 28px 32px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3);
}
.hero-badge {
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white; padding: 6px 16px; border-radius: 50px;
    font-size: 0.82rem; font-weight: 600; letter-spacing: 1px;
    display: inline-block; box-shadow: 0 2px 10px rgba(232,92,0,0.35);
}
.hero-title { color: white; font-size: 2rem; font-weight: 800; line-height: 1.2; }
.hero-text { color: rgba(255,200,170,0.7); font-size: 0.95rem; max-width: 520px; line-height: 1.7; margin-bottom: 0; }

.hero-btn-primary {
    display: inline-block;
    padding: 12px 28px; border-radius: 50px;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white; font-weight: 700; font-size: 0.9rem;
    text-decoration: none; transition: 0.2s;
    box-shadow: 0 4px 16px rgba(232,92,0,0.35);
}
.hero-btn-primary:hover { opacity: 0.92; color: white; transform: scale(1.02); }

/* Alert flashes */
.alert-flash {
    padding: 12px 20px; border-radius: 12px;
    font-weight: 600; font-size: 0.9rem;
    backdrop-filter: blur(8px);
}
.alert-flash.success { background: rgba(232,92,0,0.12); border: 1px solid rgba(255,153,68,0.25); color: #ff9944; }
.alert-flash.error   { background: rgba(220,53,69,0.15); border: 1px solid rgba(255,107,129,0.3); color: #ff8a9e; }

/* Participation cards */
.participations-list { display: flex; flex-direction: column; gap: 10px; }

.participation-card {
    display: flex;
    align-items: stretch;
    background: rgba(18,5,20,0.5);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,140,50,0.1);
    border-radius: 16px;
    overflow: hidden;
    transition: 0.2s;
}
.participation-card:hover { border-color: rgba(255,140,50,0.25); background: rgba(232,92,0,0.04); }

.pc-left {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 80px;
    background: rgba(232,92,0,0.06);
    border-right: 1px solid rgba(255,140,50,0.08);
}

.pc-date-box {
    text-align: center;
    padding: 8px;
}
.pc-day { font-size: 1.4rem; font-weight: 800; color: white; line-height: 1; }
.pc-month { font-size: 10px; color: rgba(255,200,170,0.5); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }

.pc-body {
    padding: 14px 18px;
    flex: 1;
    min-width: 0;
}

.pc-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: white;
    margin: 0 0 4px;
}

.pc-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    font-size: 0.78rem;
    color: rgba(255,200,170,0.5);
}
.pc-club {
    background: rgba(232,92,0,0.1);
    border: 1px solid rgba(255,140,50,0.15);
    color: #ff9944;
    padding: 1px 8px;
    border-radius: 50px;
    font-weight: 600;
}

.pc-status {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 2px 8px;
    border-radius: 50px;
    white-space: nowrap;
}
.pc-status.inscrit { background: rgba(99,102,241,0.1); color: #a5b4fc; border: 1px solid rgba(165,180,252,0.2); }
.pc-status.present { background: rgba(34,197,94,0.1); color: #4ade80; border: 1px solid rgba(74,222,128,0.2); }
.pc-status.absent  { background: rgba(220,53,69,0.1); color: #ff6b81; border: 1px solid rgba(255,107,129,0.2); }

.pc-upcoming-badge { font-size: 0.6rem; font-weight: 600; color: #80b0ff; text-transform: uppercase; letter-spacing: 0.5px; }
.pc-past-badge     { font-size: 0.6rem; font-weight: 600; color: rgba(255,200,170,0.3); text-transform: uppercase; letter-spacing: 0.5px; }
.pc-now-badge      { font-size: 0.6rem; font-weight: 600; color: #4ade80; text-transform: uppercase; letter-spacing: 0.5px; }

.pc-footer { display: flex; justify-content: flex-end; }
.pc-btn {
    padding: 6px 14px;
    border-radius: 8px;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white;
    font-weight: 600;
    font-size: 0.78rem;
    text-decoration: none;
    transition: 0.2s;
}
.pc-btn:hover { opacity: 0.92; color: white; }

.empty-box {
    padding: 60px 20px; border-radius: 20px;
    background: rgba(18,5,20,0.45);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,140,50,0.08);
}
</style>

{% endblock %}
