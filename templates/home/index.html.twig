{% extends 'base.html.twig' %}

{% block title %}ISET Clubs — Accueil{% endblock %}

{% block body %}

{# ── Animated blob background ── #}
<div class="blob-bg" aria-hidden="true">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
  <div class="blob blob-4"></div>
  <div class="blob blob-5"></div>
</div>

<div class="wrap">

  {% include 'navbar/navbar.html.twig' %}

  <!-- HERO -->
  <section class="hero">
    <div class="hero-orb orb1"></div>
    <div class="hero-orb orb2"></div>
    <div class="hero-orb orb3"></div>
    <div class="hero-inner">
      <div class="hero-tag">
        <span class="hero-tag-dot"></span>
        ISET Zaghouan · {{ 'now'|date('Y') }}–{{ 'now'|date('Y')+1 }}
      </div>
      <h1>La vie étudiante,<br><span>réinventée</span></h1>
      <p class="hero-sub">
        Découvrez les clubs, participez aux événements et postulez aux recrutements
        de l'ISET Zaghouan — tout en un seul endroit.
      </p>
      <div class="hero-btns">
        <a href="{{ path('app_club_index') }}" class="hero-btn hero-btn-primary">
          Explorer les clubs
        </a>
        <a href="{{ path('app_evenement_index') }}" class="hero-btn hero-btn-secondary">
          Voir les événements
        </a>
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <div class="stats-strip">
    <div class="stat-item">
      <div class="stat-n">{{ clubCount }}</div>
      <div class="stat-l">Clubs actifs</div>
    </div>
    <div class="stat-item">
      <div class="stat-n">{{ eventCount }}</div>
      <div class="stat-l">Événements</div>
    </div>
    <div class="stat-item">
      <div class="stat-n">{{ totalUsers }}</div>
      <div class="stat-l">Étudiants inscrits</div>
    </div>
    <div class="stat-item">
      <div class="stat-n">{{ recruitmentCount }}</div>
      <div class="stat-l">Recrutements ouverts</div>
    </div>
  </div>

  <!-- CLUBS SECTION -->
  <section class="section">
    <div class="sec-header">
      <h2>Clubs à la une</h2>
      <a href="{{ path('app_club_index') }}" class="sec-link">
        Voir tous les clubs
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
    <div class="clubs-grid">
      {% for club in activeClubs|slice(0, 3) %}
        <div class="home-club-card">
          <div class="home-club-banner" style="background:linear-gradient(135deg, #e85c00, #b81c05)">
            {% if club.logo %}
              <img src="{{ asset('uploads/logos/' ~ club.logo) }}" alt="{{ club.name }}">
            {% else %}
              <span class="home-club-letter">{{ club.name|slice(0,1)|upper }}</span>
            {% endif %}
            <div class="home-club-overlay"></div>
          </div>
          <div class="home-club-info">
            <div class="home-club-name">{{ club.name }}</div>
            <div class="home-club-desc">
              {{ club.description|length > 80 ? club.description|slice(0,80) ~ '...' : club.description }}
            </div>
            <div class="home-club-foot">
              <span class="home-club-members">{{ club.clubMembers|length }} membre(s)</span>
              <span class="pill pill-active">Actif</span>
            </div>
          </div>
        </div>
      {% else %}
        <div class="home-club-card" style="grid-column:1/-1;padding:40px;text-align:center;background:rgba(18,5,20,0.3);border-radius:16px">
          <p style="color:rgba(255,200,170,0.6);margin:0">Aucun club pour le moment.</p>
        </div>
      {% endfor %}
    </div>
  </section>

  <!-- EVENTS SECTION -->
  <section class="section" style="padding-top:0">
    <div class="sec-header">
      <h2>Prochains événements</h2>
      <a href="{{ path('app_evenement_index') }}" class="sec-link">
        Voir tous
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
    <div class="ev-list">
      {% for event in upcomingEvents|slice(0, 3) %}
        <div class="ev-item">
          <div class="ev-date-box">
            <div class="ev-day">{{ event.dateDebut ? event.dateDebut|date('d') : '—' }}</div>
            <div class="ev-month">{{ event.dateDebut ? event.dateDebut|date('M') : '' }}</div>
          </div>
          <div class="ev-sep"></div>
          <div class="ev-info">
            <h4>{{ event.nomEvenement }}</h4>
            <p>
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {{ event.lieu ?? 'En ligne' }} ·
              {{ event.dateDebut ? event.dateDebut|date('H:i') : '—' }}
              {% if event.dateFin %} → {{ event.dateFin|date('H:i') }}{% endif %}
              {% if event.club %}
                <span class="home-ev-club">{{ event.club.name }}</span>
              {% endif %}
            </p>
          </div>
          <div class="ev-action">
            <a href="{{ path('app_evenement_show', {'id': event.id}) }}" class="ev-btn">Voir</a>
          </div>
        </div>
      {% else %}
        <div class="ev-item" style="padding:30px;justify-content:center;background:rgba(18,5,20,0.3)">
          <p style="color:rgba(255,200,170,0.6);margin:0">Aucun événement à venir.</p>
        </div>
      {% endfor %}
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features">
    <div class="sec-header" style="margin-bottom:0">
      <h2>Pourquoi ISET Clubs ?</h2>
    </div>
    <div class="feat-grid">
      <div class="feat-card">
        <div class="feat-icon" style="background:rgba(232,92,0,0.15)">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ff8c42" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <h3>Tout centralisé</h3>
        <p>Clubs, événements et recrutements réunis en un seul endroit. Fini les formulaires Google éparpillés.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon" style="background:rgba(184,28,5,0.15)">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b81c05" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <h3>Notifications en temps réel</h3>
        <p>Recevez des alertes pour les nouveaux événements, les validations de candidature et bien plus.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon" style="background:rgba(255,153,68,0.12)">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ff9944" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Sécurisé & vérifié</h3>
        <p>Comptes étudiants vérifiés uniquement. Vos données sont protégées et votre vie privée respectée.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta-orb cta-orb-1"></div>
    <div class="cta-orb cta-orb-2"></div>
    <h2>Prêt à rejoindre la communauté ?</h2>
    <p>Créez votre compte étudiant gratuitement et commencez à explorer dès aujourd'hui.</p>
    <div class="cta-btns">
      {% if app.user %}
        <a href="{{ path('app_club_index') }}" class="hero-btn hero-btn-primary">
          Explorer les clubs
        </a>
      {% else %}
        <a href="{{ path('app_register') }}" class="hero-btn hero-btn-primary">
          Créer mon compte
        </a>
        <a href="{{ path('app_login') }}" class="hero-btn hero-btn-secondary">
          Se connecter
        </a>
      {% endif %}
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-logo">
      <span class="footer-logo-icon">C</span>
      ISET Clubs
    </div>
    <div class="footer-copy">© {{ 'now'|date('Y') }}–{{ 'now'|date('Y')+1 }} ISET Zaghouan · Tous droits réservés</div>
  </footer>

</div>

<style>

/* ── Blob background ── */
.blob-bg {
  position: fixed; inset: 0; z-index: -1; overflow: hidden;
  background: radial-gradient(ellipse at 70% 40%, #e84c0e 0%, #b81c05 35%, #7a0a0e 65%, #2d0520 100%);
}
.blob {
  position: absolute; border-radius: 50%; mix-blend-mode: screen; filter: blur(2px);
}
.blob-1 {
  width: 340px; height: 340px;
  background: radial-gradient(circle at 40% 35%, #ffaa00, #e85c00 55%, transparent 80%);
  top: -60px; right: 100px; animation: float1 9s ease-in-out infinite;
}
.blob-2 {
  width: 180px; height: 180px;
  background: radial-gradient(circle at 45% 40%, #ffd060, #ff8800 60%, transparent 80%);
  top: 20px; right: 330px; animation: float2 11s ease-in-out infinite;
}
.blob-3 {
  width: 420px; height: 360px;
  background: radial-gradient(circle at 50% 45%, #ff6a00 0%, #dd2200 50%, transparent 75%);
  bottom: -100px; right: -40px; animation: float3 13s ease-in-out infinite;
}
.blob-4 {
  width: 260px; height: 200px;
  background: radial-gradient(circle at 50% 50%, #ff4500 0%, #9e0a00 55%, transparent 80%);
  bottom: 20px; left: 80px; animation: float4 10s ease-in-out infinite;
}
.blob-5 {
  width: 90px; height: 90px;
  background: radial-gradient(circle at 45% 40%, #ffc040, #ff7800 60%, transparent 80%);
  top: 130px; right: 260px; animation: float5 7s ease-in-out infinite;
}

@keyframes float1 {
  0%,100% { transform: translate(0,0) scale(1); }
  33% { transform: translate(-18px, 22px) scale(1.04); }
  66% { transform: translate(12px, -14px) scale(0.97); }
}
@keyframes float2 {
  0%,100% { transform: translate(0,0) scale(1); }
  40% { transform: translate(20px, 18px) scale(1.06); }
  70% { transform: translate(-10px, -8px) scale(0.95); }
}
@keyframes float3 {
  0%,100% { transform: translate(0,0) scale(1); }
  30% { transform: translate(-25px, -20px) scale(1.03); }
  60% { transform: translate(15px, 12px) scale(0.98); }
}
@keyframes float4 {
  0%,100% { transform: translate(0,0) scale(1); }
  45% { transform: translate(22px, -18px) scale(1.05); }
  75% { transform: translate(-12px, 10px) scale(0.96); }
}
@keyframes float5 {
  0%,100% { transform: translate(0,0) scale(1); }
  50% { transform: translate(-14px, 20px) scale(1.1); }
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body { min-height: 100vh; }

::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,200,170,0.2); border-radius: 20px; }

.wrap { color: white; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; }

/* ── HERO ── */
.hero { padding: 70px 32px 60px; text-align: center; position: relative; overflow: hidden; }
.hero-orb { position: absolute; border-radius: 50%; pointer-events: none; }
.orb1 { width: 400px; height: 400px; background: rgba(232,92,0,0.1); top: -100px; left: -100px; }
.orb2 { width: 300px; height: 300px; background: rgba(184,28,5,0.08); bottom: -80px; right: -60px; }
.orb3 { width: 200px; height: 200px; background: rgba(255,140,50,0.06); top: 50px; right: 100px; }
.hero-inner { position: relative; z-index: 1; }
.hero-tag {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(232,92,0,0.1); border: 1px solid rgba(255,140,50,0.2);
  border-radius: 50px; padding: 6px 16px; font-size: 12px;
  color: rgba(255,200,170,0.7); margin-bottom: 24px;
}
.hero-tag-dot { width: 6px; height: 6px; border-radius: 50%; background: #ff8c42; }
.hero h1 {
  font-size: 2.8rem; font-weight: 800; line-height: 1.15; color: white;
  margin-bottom: 16px; max-width: 640px; margin-left: auto; margin-right: auto;
}
.hero h1 span {
  background: linear-gradient(135deg, #ffdd77, #ffaa33, #ff8844);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  text-shadow: 0 0 30px rgba(255,200,100,0.15);
}
.hero-sub {
  font-size: 1rem; color: rgba(255,220,190,0.85);
  line-height: 1.7; max-width: 480px; margin: 0 auto 32px;
  text-shadow: 0 2px 12px rgba(0,0,0,0.5);
}
.hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
.hero-btn {
  padding: 12px 28px; border-radius: 50px; font-size: 0.9rem; font-weight: 700;
  cursor: pointer; border: none; letter-spacing: 0.3px; transition: 0.2s;
  text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
}
.hero-btn-primary {
  background: linear-gradient(135deg, #e85c00, #b81c05); color: white;
  box-shadow: 0 4px 16px rgba(232,92,0,0.35);
}
.hero-btn-primary:hover { opacity: 0.92; transform: scale(1.02); box-shadow: 0 6px 24px rgba(232,92,0,0.5); }
.hero-btn-secondary {
  background: rgba(232,92,0,0.08); color: rgba(255,220,190,0.85);
  border: 1px solid rgba(255,140,50,0.2);
}
.hero-btn-secondary:hover { background: rgba(232,92,0,0.15); color: white; }

/* ── STATS ── */
.stats-strip {
  display: flex;
  border-top: 1px solid rgba(255,140,50,0.08);
  border-bottom: 1px solid rgba(255,140,50,0.08);
  background: rgba(18,5,20,0.35);
}
.stat-item {
  flex: 1; padding: 20px; text-align: center;
  border-right: 1px solid rgba(255,140,50,0.06);
}
.stat-item:last-child { border-right: none; }
.stat-n { font-size: 1.8rem; font-weight: 800; color: white; }
.stat-l { font-size: 11px; color: rgba(255,200,170,0.5); margin-top: 3px; text-transform: uppercase; letter-spacing: 0.8px; }

/* ── SECTIONS ── */
.section { padding: 48px 32px; }
.sec-header {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;
}
.sec-header h2 { font-size: 1.3rem; font-weight: 700; color: white; }
.sec-link {
  font-size: 13px; color: #ffaa55; text-decoration: none;
  display: flex; align-items: center; gap: 4px; transition: 0.2s;
  text-shadow: 0 2px 10px rgba(0,0,0,0.5);
}
.sec-link:hover { color: #ffc080; }

/* ── CLUBS GRID ── */
.clubs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.home-club-card {
  background: rgba(18,5,20,0.4);
  border: 1px solid rgba(255,140,50,0.1);
  border-radius: 18px; overflow: hidden; transition: 0.25s;
}
.home-club-card:hover { transform: translateY(-4px); border-color: rgba(255,140,50,0.3); }
.home-club-banner {
  height: 110px; display: flex; align-items: center; justify-content: center;
  font-size: 2.8rem; position: relative; overflow: hidden;
}
.home-club-banner img { width: 100%; height: 100%; object-fit: cover; }
.home-club-letter {
  font-size: 2.8rem; font-weight: 800; color: rgba(255,255,255,0.3);
  position: relative; z-index: 1;
}
.home-club-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(18,5,20,0.6), transparent);
}
.home-club-info { padding: 14px; }
.home-club-name { font-size: 13px; font-weight: 700; color: white; margin-bottom: 4px; }
.home-club-desc { font-size: 11px; color: rgba(255,200,170,0.55); line-height: 1.5; margin-bottom: 10px; }
.home-club-foot { display: flex; align-items: center; justify-content: space-between; }
.home-club-members { font-size: 11px; color: rgba(255,200,170,0.45); display: flex; align-items: center; gap: 4px; }
.pill { font-size: 10px; padding: 2px 9px; border-radius: 20px; font-weight: 600; }
.pill-active { background: rgba(232,92,0,0.15); color: #ff9944; border: 1px solid rgba(255,153,68,0.2); }

/* ── EVENTS ── */
.ev-list { display: flex; flex-direction: column; gap: 10px; }
.ev-item {
  background: rgba(18,5,20,0.35);
  border: 1px solid rgba(255,140,50,0.1);
  border-radius: 14px; padding: 14px 16px;
  display: flex; align-items: center; gap: 14px; transition: 0.2s;
}
.ev-item:hover { border-color: rgba(255,140,50,0.25); background: rgba(232,92,0,0.05); }
.ev-date-box {
  text-align: center; min-width: 38px;
  background: rgba(232,92,0,0.12); border-radius: 10px;
  padding: 8px 6px; border: 1px solid rgba(255,140,50,0.15);
}
.ev-day { font-size: 1.2rem; font-weight: 800; color: white; line-height: 1; }
.ev-month { font-size: 9px; color: rgba(255,200,170,0.6); text-transform: uppercase; letter-spacing: 1px; }
.ev-sep { width: 1px; height: 36px; background: rgba(255,140,50,0.1); flex-shrink: 0; }
.ev-info { flex: 1; min-width: 0; }
.ev-info h4 { font-size: 13px; font-weight: 700; color: white; margin-bottom: 3px; }
.ev-info p {
  font-size: 11px; color: rgba(255,200,170,0.5);
  display: flex; align-items: center; gap: 5px; margin: 0;
}
.ev-info p svg { flex-shrink: 0; color: #ff8c42; }
.home-ev-club {
    background: rgba(232,92,0,0.1);
    border: 1px solid rgba(255,140,50,0.15);
    color: #ff9944;
    padding: 1px 7px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 10px;
}
.ev-action { margin-left: auto; flex-shrink: 0; }
.ev-btn {
  display: inline-block; font-size: 11px; padding: 6px 14px; border-radius: 8px;
  background: linear-gradient(135deg, #e85c00, #b81c05); color: white;
  border: none; cursor: pointer; font-weight: 600; white-space: nowrap;
  text-decoration: none; transition: 0.2s;
}
.ev-btn:hover { opacity: 0.92; }

/* ── FEATURES ── */
.features {
  padding: 48px 32px;
  background: rgba(18,5,20,0.25);
  border-top: 1px solid rgba(255,140,50,0.06);
  border-bottom: 1px solid rgba(255,140,50,0.06);
}
.feat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 24px; }
.feat-card {
  background: rgba(18,5,20,0.3);
  border: 1px solid rgba(255,140,50,0.08);
  border-radius: 16px; padding: 22px 20px;
}
.feat-icon {
  width: 40px; height: 40px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center; margin-bottom: 14px;
}
.feat-card h3 { font-size: 13px; font-weight: 700; color: white; margin-bottom: 6px; }
.feat-card p { font-size: 12px; color: rgba(255,200,170,0.5); line-height: 1.6; margin: 0; }

/* ── CTA ── */
.cta { padding: 60px 32px; text-align: center; position: relative; overflow: hidden; }
.cta-orb { position: absolute; border-radius: 50%; pointer-events: none; }
.cta-orb-1 { width: 300px; height: 300px; background: rgba(232,92,0,0.08); top: -80px; left: -60px; }
.cta-orb-2 { width: 200px; height: 200px; background: rgba(184,28,5,0.06); bottom: -60px; right: -40px; }
.cta h2 {
  font-size: 1.8rem; font-weight: 800; color: white;
  margin-bottom: 10px; position: relative; z-index: 1;
}
.cta p {
  font-size: 0.9rem; color: rgba(255,220,190,0.85);
  margin-bottom: 24px; position: relative; z-index: 1;
  text-shadow: 0 2px 12px rgba(0,0,0,0.5);
}
.cta-btns { display: flex; gap: 10px; justify-content: center; position: relative; z-index: 1; flex-wrap: wrap; }

/* ── FOOTER ── */
.footer {
  padding: 20px 32px;
  border-top: 1px solid rgba(255,140,50,0.06);
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(18,5,20,0.4);
}
.footer-logo {
  font-size: 13px; font-weight: 600; color: rgba(255,200,170,0.5);
  display: flex; align-items: center; gap: 8px;
}
.footer-logo-icon {
  width: 22px; height: 22px; border-radius: 6px;
  background: linear-gradient(135deg, #e85c00, #b81c05);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 800; color: white;
}
.footer-copy { font-size: 12px; color: rgba(255,220,190,0.7); text-shadow: 0 2px 10px rgba(0,0,0,0.5); }

/* ── Responsive ── */
@media (max-width: 768px) {
  .hero h1 { font-size: 2rem; }
  .clubs-grid { grid-template-columns: 1fr; }
  .feat-grid { grid-template-columns: 1fr; }
  .stats-strip { flex-wrap: wrap; }
  .stat-item { flex: 1 1 45%; border-bottom: 1px solid rgba(255,140,50,0.06); }
  .nav-center { display: none; }
  .hero { padding: 50px 20px 40px; }
  .section { padding: 32px 20px; }
  .features { padding: 32px 20px; }
  .cta { padding: 40px 20px; }
