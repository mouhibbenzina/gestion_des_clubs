{% extends 'base.html.twig' %}

{% block title %}Événements ISET Zaghouan{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

{# ── Animated blob background ── #}
<div class="blob-bg" id="blobBg" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>
</div>

<div class="ev-page py-4">
    <div class="container">

        <!-- HERO -->
        <div class="hero-section mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg-8">
                    <span class="hero-badge">Événements</span>
                    <h1 class="hero-title mt-2">Événements de l'ISET Zaghouan</h1>
                    <p class="hero-text mt-3">
                        Découvrez les événements organisés par les clubs étudiants.
                        Participez, apprenez et vivez des moments inoubliables.
                    </p>
                    <div class="mt-3">
                        <a href="{{ path('app_evenement_new') }}" class="hero-btn-primary">
                            + Créer un événement
                        </a>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="hero-stats">
                        <div class="stat-box">
                            <div class="stat-num">{{ evenements|length }}</div>
                            <div class="stat-lbl">Événements</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-num">—</div>
                            <div class="stat-lbl">À venir</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-num">—</div>
                            <div class="stat-lbl">Participants</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- EVENTS GRID -->
        <div class="row g-4">

            {% for evenement in evenements %}

                <div class="col-md-6 col-lg-4">
                    <div class="ev-card h-100">

                        <div class="ev-banner">
                            {% if evenement.image %}
                                <img src="{{ asset('uploads/events/' ~ evenement.image) }}" alt="{{ evenement.nomEvenement }}">
                            {% else %}
                                <div class="default-banner">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                </div>
                            {% endif %}
                            <div class="overlay"></div>

                            <div class="ev-date-badge">
                                <div class="ev-day">{{ evenement.dateDebut ? evenement.dateDebut|date('d') : '—' }}</div>
                                <div class="ev-month">{{ evenement.dateDebut ? evenement.dateDebut|date('M') : '' }}</div>
                            </div>

                            <div class="ev-status-badge">
                                {% if evenement.status == 'actif' or evenement.status == 'Actif' or evenement.status == true %}
                                    <span class="status active">Actif</span>
                                {% else %}
                                    <span class="status inactive">Terminé</span>
                                {% endif %}
                            </div>
                        </div>

                        <div class="ev-content">
                            <h3 class="ev-title">{{ evenement.nomEvenement }}</h3>

                            <div class="ev-meta">
                                <div class="ev-meta-item">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                    {{ evenement.lieu }}
                                </div>
                                <div class="ev-meta-item">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    {{ evenement.dateDebut ? evenement.dateDebut|date('H:i') : '—' }}
                                    {% if evenement.dateFin %} → {{ evenement.dateFin|date('H:i') }}{% endif %}
                                </div>
                            </div>

                            <p class="ev-description">
                                {{ evenement.description|length > 110
                                    ? evenement.description|slice(0,110) ~ '...'
                                    : evenement.description }}
                            </p>

                            <div class="ev-actions">
                                <a href="{{ path('app_evenement_show', {'id': evenement.id}) }}" class="view-btn">
                                    Voir l'événement
                                </a>
                                <a href="{{ path('app_evenement_edit', {'id': evenement.id}) }}" class="ev-edit-btn">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </a>
                            </div>
                        </div>

                    </div>
                </div>

            {% else %}

                <div class="col-12">
                    <div class="empty-box text-center">
                        <h2 class="fw-bold text-white mb-3">Aucun événement disponible</h2>
                        <p class="text-light opacity-75 mb-0">Les événements apparaîtront ici une fois ajoutés.</p>
                    </div>
                </div>

            {% endfor %}

        </div>

    </div>
</div>

<style>

.blob-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background: radial-gradient(ellipse at 70% 40%, #e84c0e 0%, #b81c05 35%, #7a0a0e 65%, #2d0520 100%);
}

.blob {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: screen;
    filter: blur(2px);
}

.blob-1 {
    width: 340px; height: 340px;
    background: radial-gradient(circle at 40% 35%, #ffaa00, #e85c00 55%, transparent 80%);
    top: -60px; right: 100px;
    animation: float1 9s ease-in-out infinite;
}
.blob-2 {
    width: 180px; height: 180px;
    background: radial-gradient(circle at 45% 40%, #ffd060, #ff8800 60%, transparent 80%);
    top: 20px; right: 330px;
    animation: float2 11s ease-in-out infinite;
}
.blob-3 {
    width: 420px; height: 360px;
    background: radial-gradient(circle at 50% 45%, #ff6a00 0%, #dd2200 50%, transparent 75%);
    bottom: -100px; right: -40px;
    animation: float3 13s ease-in-out infinite;
}
.blob-4 {
    width: 260px; height: 200px;
    background: radial-gradient(circle at 50% 50%, #ff4500 0%, #9e0a00 55%, transparent 80%);
    bottom: 20px; left: 80px;
    animation: float4 10s ease-in-out infinite;
}
.blob-5 {
    width: 90px; height: 90px;
    background: radial-gradient(circle at 45% 40%, #ffc040, #ff7800 60%, transparent 80%);
    top: 130px; right: 260px;
    animation: float5 7s ease-in-out infinite;
}

.sparkle {
    position: absolute;
    width: 3px; height: 3px;
    background: rgba(255,255,255,0.55);
    border-radius: 50%;
}

@keyframes float1 {
    0%,100% { transform: translate(0,0) scale(1); }
    33% { transform: translate(-18px, 22px) scale(1.04); }
    66% { transform: translate(12px, -14px) scale(0.97); }
}
@keyframes float2 {
    0%,100% { transform: translate(0,0) scale(1); }
    40% { transform: translate(20px, 18px) scale(1.06); }
    70% { transform: translate(-10px, -8px) scale(0.95); }
}
@keyframes float3 {
    0%,100% { transform: translate(0,0) scale(1); }
    30% { transform: translate(-25px, -20px) scale(1.03); }
    60% { transform: translate(15px, 12px) scale(0.98); }
}
@keyframes float4 {
    0%,100% { transform: translate(0,0) scale(1); }
    45% { transform: translate(22px, -18px) scale(1.05); }
    75% { transform: translate(-12px, 10px) scale(0.96); }
}
@keyframes float5 {
    0%,100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(-14px, 20px) scale(1.1); }
}

body {
    min-height: 100vh;
}

::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,200,170,0.2); border-radius: 20px; }

.ev-page .container {
    max-width: 1480px;
}
.ev-page { min-height: 100vh; }

/* ── Hero section ── */
.hero-section {
    background: rgba(18, 5, 20, 0.55);
    border: 1px solid rgba(255, 140, 50, 0.15);
    backdrop-filter: blur(18px);
    border-radius: 20px;
    padding: 28px 32px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.06);
}
.hero-section::before {
    content: '';
    position: absolute;
    width: 240px; height: 240px;
    background: radial-gradient(circle, rgba(232,76,14,0.12), transparent 70%);
    border-radius: 50%;
    top: -100px; right: -80px;
    pointer-events: none;
}

.hero-badge {
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    box-shadow: 0 2px 10px rgba(232,92,0,0.35);
}

.hero-title {
    color: white;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
}

.hero-text {
    color: rgba(255,200,170,0.7);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 0;
}

.hero-btn-primary {
    display: inline-block;
    padding: 10px 22px;
    border-radius: 50px;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white;
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    transition: 0.2s ease;
    box-shadow: 0 4px 16px rgba(232,92,0,0.35);
}
.hero-btn-primary:hover { opacity: 0.92; color: white; transform: scale(1.02); box-shadow: 0 6px 24px rgba(232,92,0,0.5); }

.hero-stats {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
}

.stat-box {
    background: rgba(18,5,20,0.5);
    border: 1px solid rgba(255,140,50,0.1);
    border-radius: 16px;
    padding: 18px 20px;
    text-align: center;
    flex: 1;
    backdrop-filter: blur(8px);
}

.stat-num { font-size: 1.8rem; font-weight: 800; color: white; line-height: 1; }
.stat-lbl { font-size: 0.75rem; color: rgba(255,200,170,0.55); margin-top: 4px; font-weight: 500; }

/* ── Event card ── */
.ev-card {
    background: rgba(18, 5, 20, 0.5);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 140, 50, 0.1);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}
.ev-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 140, 50, 0.3);
    box-shadow: 0 12px 40px rgba(232,92,0,0.15);
}

.ev-banner {
    height: 130px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #e85c00, #b81c05, #7a0a0e);
}
.ev-banner img { width: 100%; height: 100%; object-fit: cover; }

.default-banner {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
}

.overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(18,5,20,0.75) 0%, rgba(0,0,0,0.15) 60%, transparent 100%);
}

.ev-date-badge {
    position: absolute;
    top: 10px; left: 12px;
    background: rgba(18,5,20,0.6);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,140,50,0.15);
    border-radius: 10px;
    padding: 5px 10px;
    text-align: center;
    z-index: 2;
}
.ev-day { font-size: 1.2rem; font-weight: 800; color: white; line-height: 1; }
.ev-month { font-size: 0.65rem; color: rgba(255,200,170,0.7); text-transform: uppercase; letter-spacing: 1px; }

.ev-status-badge {
    position: absolute;
    top: 10px; right: 12px;
    z-index: 2;
}

.status { padding: 3px 10px; border-radius: 50px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; }
.status.active { background: rgba(232,92,0,0.15); color: #ff9944; border: 1px solid rgba(255,153,68,0.25); }
.status.inactive { background: rgba(220,53,69,0.12); color: #ff6b81; border: 1px solid rgba(255,107,129,0.2); }

.ev-content {
    padding: 1rem;
    color: rgba(255,255,255,0.92);
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.15));
}

.ev-title {
    font-weight: 700;
    font-size: 0.95rem;
    margin-bottom: 8px;
    color: white;
}

.ev-meta { display: flex; flex-direction: column; gap: 4px; margin-bottom: 8px; }
.ev-meta-item {
    display: flex; align-items: center; gap: 6px;
    font-size: 0.8rem; color: rgba(255,200,170,0.6);
}
.ev-meta-item svg { flex-shrink: 0; color: #ff8c42; }

.ev-description {
    color: rgba(255,200,170,0.7);
    line-height: 1.6; font-size: 0.82rem;
    min-height: 52px;
    margin-bottom: 12px;
}

.ev-actions { display: flex; gap: 8px; }

.view-btn {
    flex: 1;
    display: block; text-align: center;
    padding: 10px 14px; border-radius: 12px;
    text-decoration: none; font-weight: 700;
    font-size: 0.85rem; color: white;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    transition: 0.25s ease;
    box-shadow: 0 4px 14px rgba(232,92,0,0.3);
}
.view-btn:hover { opacity: 0.92; color: white; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(232,92,0,0.45); }

.ev-edit-btn {
    display: flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: 12px;
    background: rgba(232,92,0,0.08);
    border: 1px solid rgba(255,140,50,0.15);
    color: rgba(255,200,170,0.7);
    text-decoration: none; flex-shrink: 0;
    transition: 0.2s ease;
}
.ev-edit-btn:hover { background: rgba(232,92,0,0.18); color: white; border-color: rgba(255,140,50,0.4); }

.empty-box {
    padding: 60px 20px; border-radius: 20px;
    background: rgba(18,5,20,0.45);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,140,50,0.08);
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
}

</style>

<script>
(function() {
    const bg = document.getElementById('blobBg');
    if (!bg) return;
    const positions = [
        [12,8],[25,60],[40,25],[55,80],[68,15],[75,50],[85,35],[90,70],[5,45],[50,5],[30,90],[60,55],[80,20],[15,75],[45,40]
    ];
    positions.forEach(([left, top]) => {
        const s = document.createElement('div');
        s.className = 'sparkle';
        s.style.left = left + '%';
        s.style.top = top + '%';
        s.style.opacity = (0.2 + Math.random() * 0.5).toFixed(2);
        s.style.animation = `float${(Math.floor(Math.random()*5)+1)} ${6+Math.random()*8}s ease-in-out infinite`;
        s.style.animationDelay = (Math.random() * 4).toFixed(1) + 's';
        bg.appendChild(s);
    });
})();
</script>

{% endblock %}