{% extends 'base.html.twig' %}

{% block title %}Événements en attente{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

<div class="blob-bg" id="blobBg" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>
</div>

<div class="pending-page py-4">
    <div class="container">

        <div class="mb-4 d-flex align-items-center gap-3 flex-wrap">
            <a href="{{ path('app_evenement_index') }}" class="back-link">← Retour aux événements</a>
            <span class="page-badge">Événements en attente</span>
        </div>

        {% for flash in app.flashes('success') %}
            <div class="alert-flash success mb-3">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('warning') %}
            <div class="alert-flash warning mb-3">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('error') %}
            <div class="alert-flash error mb-3">{{ flash }}</div>
        {% endfor %}

        {% if evenements|length == 0 %}
            <div class="empty-box text-center">
                <h2 class="fw-bold text-white mb-3">Aucun événement en attente</h2>
                <p class="text-light opacity-75 mb-0">Tous les événements ont été traités.</p>
            </div>
        {% else %}
            <div class="row g-4">
                {% for evenement in evenements %}
                <div class="col-md-6 col-lg-4">
                    <div class="pending-card">
                        <div class="pending-header">
                            <span class="pending-badge">En attente</span>
                            <span class="pending-club">{{ evenement.club.name }}</span>
                        </div>
                        <h3 class="pending-title">{{ evenement.nomEvenement }}</h3>
                        {% if evenement.description %}
                            <p class="pending-desc">{{ evenement.description|length > 120 ? evenement.description|slice(0,120) ~ '...' : evenement.description }}</p>
                        {% endif %}
                        <div class="pending-meta">
                            <span>📅 {{ evenement.dateDebut|date('d/m/Y H:i') }} → {{ evenement.dateFin|date('d/m/Y H:i') }}</span>
                            <span>📍 {{ evenement.lieu }}</span>
                        </div>
                        <div class="pending-actions mt-3">
                            <form method="POST" action="{{ path('app_evenement_review', {'id': evenement.id}) }}" class="d-flex gap-2">
                                <input type="hidden" name="action" value="approve">
                                <button type="submit" class="btn-approve">✓ Approuver</button>
                            </form>
                            <form method="POST" action="{{ path('app_evenement_review', {'id': evenement.id}) }}" class="d-flex gap-2">
                                <input type="hidden" name="action" value="reject">
                                <button type="submit" class="btn-reject">✕ Refuser</button>
                            </form>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}

    </div>
</div>

<style>

.blob-bg {
    position: fixed; inset: 0; z-index: -1; overflow: hidden;
    background: radial-gradient(ellipse at 70% 40%, #e84c0e 0%, #b81c05 35%, #7a0a0e 65%, #2d0520 100%);
}
.blob { position: absolute; border-radius: 50%; mix-blend-mode: screen; filter: blur(2px); }
.blob-1 { width: 340px; height: 340px; background: radial-gradient(circle at 40% 35%, #ffaa00, #e85c00 55%, transparent 80%); top: -60px; right: 100px; animation: float1 9s ease-in-out infinite; }
.blob-2 { width: 180px; height: 180px; background: radial-gradient(circle at 45% 40%, #ffd060, #ff8800 60%, transparent 80%); top: 20px; right: 330px; animation: float2 11s ease-in-out infinite; }
.blob-3 { width: 420px; height: 360px; background: radial-gradient(circle at 50% 45%, #ff6a00 0%, #dd2200 50%, transparent 75%); bottom: -100px; right: -40px; animation: float3 13s ease-in-out infinite; }
.blob-4 { width: 260px; height: 200px; background: radial-gradient(circle at 50% 50%, #ff4500 0%, #9e0a00 55%, transparent 80%); bottom: 20px; left: 80px; animation: float4 10s ease-in-out infinite; }
.blob-5 { width: 90px; height: 90px; background: radial-gradient(circle at 45% 40%, #ffc040, #ff7800 60%, transparent 80%); top: 130px; right: 260px; animation: float5 7s ease-in-out infinite; }
@keyframes float1 { 0%,100% { transform: translate(0,0) scale(1); } 33% { transform: translate(-18px, 22px) scale(1.04); } 66% { transform: translate(12px, -14px) scale(0.97); } }
@keyframes float2 { 0%,100% { transform: translate(0,0) scale(1); } 40% { transform: translate(20px, 18px) scale(1.06); } 70% { transform: translate(-10px, -8px) scale(0.95); } }
@keyframes float3 { 0%,100% { transform: translate(0,0) scale(1); } 30% { transform: translate(-25px, -20px) scale(1.03); } 60% { transform: translate(15px, 12px) scale(0.98); } }
@keyframes float4 { 0%,100% { transform: translate(0,0) scale(1); } 45% { transform: translate(22px, -18px) scale(1.05); } 75% { transform: translate(-12px, 10px) scale(0.96); } }
@keyframes float5 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-14px, 20px) scale(1.1); } }

.sparkle { position: absolute; width: 3px; height: 3px; background: rgba(255,255,255,0.55); border-radius: 50%; }
body { min-height: 100vh; }
::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,200,170,0.2); border-radius: 20px; }

.pending-page { min-height: 100vh; }
.pending-page .container { max-width: 1480px; }

.back-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: rgba(255,200,170,0.6); text-decoration: none;
    font-size: 0.85rem; font-weight: 500;
    padding: 7px 16px; border-radius: 50px;
    border: 1px solid rgba(255,140,50,0.15);
    background: rgba(232,92,0,0.08);
    transition: 0.2s ease;
}
.back-link:hover { color: white; background: rgba(232,92,0,0.18); }

.page-badge {
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white; padding: 6px 16px; border-radius: 50px;
    font-size: 0.82rem; font-weight: 600; letter-spacing: 1px;
}

.pending-card {
    background: rgba(18,5,20,0.5);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,140,50,0.12);
    border-radius: 16px;
    padding: 1.25rem;
    height: 100%;
    transition: 0.3s;
}
.pending-card:hover {
    border-color: rgba(255,140,50,0.3);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(232,92,0,0.12);
}

.pending-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 10px;
}
.pending-badge {
    background: rgba(250,204,21,0.12);
    color: #facc15; border: 1px solid rgba(250,204,21,0.2);
    padding: 3px 10px; border-radius: 50px;
    font-size: 0.7rem; font-weight: 600;
}
.pending-club {
    color: rgba(255,200,170,0.5);
    font-size: 0.78rem; font-weight: 500;
}
.pending-title {
    font-size: 1rem; font-weight: 700; color: white;
    margin-bottom: 6px;
}
.pending-desc {
    color: rgba(255,200,170,0.65);
    font-size: 0.82rem; line-height: 1.6;
    margin-bottom: 10px;
}
.pending-meta {
    display: flex; flex-direction: column; gap: 3px;
    color: rgba(255,200,170,0.45);
    font-size: 0.78rem;
}
.pending-actions {
    display: flex; gap: 8px;
}
.btn-approve {
    padding: 8px 18px; border: none; border-radius: 10px;
    background: rgba(34,197,94,0.12);
    color: #4ade80; font-weight: 600; font-size: 0.82rem;
    cursor: pointer; transition: 0.2s; font-family: inherit;
    border: 1px solid rgba(74,222,128,0.2);
}
.btn-approve:hover { background: rgba(34,197,94,0.2); }
.btn-reject {
    padding: 8px 18px; border: none; border-radius: 10px;
    background: rgba(220,53,69,0.12);
    color: #ff6b81; font-weight: 600; font-size: 0.82rem;
    cursor: pointer; transition: 0.2s; font-family: inherit;
    border: 1px solid rgba(255,107,129,0.2);
}
.btn-reject:hover { background: rgba(220,53,69,0.2); }

.alert-flash {
    padding: 12px 20px; border-radius: 12px;
    font-weight: 600; font-size: 0.9rem;
    backdrop-filter: blur(8px);
}
.alert-flash.success { background: rgba(232,92,0,0.12); border: 1px solid rgba(255,153,68,0.25); color: #ff9944; }
.alert-flash.warning { background: rgba(220,53,69,0.1); border: 1px solid rgba(255,107,129,0.2); color: #ff6b81; }
.alert-flash.error   { background: rgba(220,53,69,0.15); border: 1px solid rgba(255,107,129,0.3); color: #ff8a9e; }

.empty-box {
    padding: 60px 20px; border-radius: 20px;
    background: rgba(18,5,20,0.45);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,140,50,0.08);
}

</style>

<script>
(function() {
    const bg = document.getElementById('blobBg');
    if (!bg) return;
    const positions = [[12,8],[25,60],[40,25],[55,80],[68,15],[75,50],[85,35],[90,70],[5,45],[50,5],[30,90],[60,55],[80,20],[15,75],[45,40]];
    positions.forEach(([left, top]) => {
        const s = document.createElement('div');
        s.className = 'sparkle';
        s.style.left = left + '%';
        s.style.top = top + '%';
        s.style.opacity = (0.2 + Math.random() * 0.5).toFixed(2);
        s.style.animation = `float${(Math.floor(Math.random()*5)+1)} ${6+Math.random()*8}s ease-in-out infinite`;
        s.style.animationDelay = (Math.random() * 4).toFixed(1) + 's';
        bg.appendChild(s);
    });
})();
</script>

{% endblock %}
