{% extends 'base.html.twig' %}

{% block title %}Participants — {{ evenement.nomEvenement }}{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

<div class="blob-bg" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>
</div>

<div class="page py-4">
    <div class="container">

        <div class="mb-4 d-flex align-items-center gap-3 flex-wrap">
            <a href="{{ path('app_evenement_show', {'id': evenement.id}) }}" class="back-link">
                ← Retour à l'événement
            </a>
            <span class="page-badge">Participants</span>
        </div>

        {% for flash in app.flashes('success') %}
            <div class="alert-flash success mb-3">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('error') %}
            <div class="alert-flash error mb-3">{{ flash }}</div>
        {% endfor %}

        <div class="manage-card">
            <div class="card-header">
                <h2 class="card-title">{{ evenement.nomEvenement }} — Participants ({{ participations|length }})</h2>
                <span class="card-club">{{ evenement.club ? evenement.club.name : '—' }}</span>
            </div>

            <div class="card-body p-0">
                <table class="manage-table">
                    <thead>
                        <tr>
                            <th>Participant</th>
                            <th>Inscrit le</th>
                            <th>Statut</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for p in participations %}
                        <tr>
                            <td>
                                <div class="member-info">
                                    <div class="member-avatar">{{ p.user.nom|slice(0,1)|upper }}{{ p.user.prenom|slice(0,1)|upper }}</div>
                                    <div>
                                        <div class="member-name">{{ p.user.nom }} {{ p.user.prenom }}</div>
                                        <div class="member-email">{{ p.user.email }}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted">{{ p.registeredAt ? p.registeredAt|date('d/m/Y') : '—' }}</td>
                            <td>
                                <span class="pc-status {{ p.presenceStatus }}">
                                    {{ p.presenceStatus == 'present' ? 'Présent' : p.presenceStatus == 'absent' ? 'Absent' : 'Inscrit' }}
                                </span>
                            </td>
                            <td class="text-end">
                                {% if p.presenceStatus != 'present' %}
                                <form method="POST" action="{{ path('app_participation_presence', {'id': p.id, 'status': 'present'}) }}" class="d-inline">
                                    <button type="submit" class="btn-sm-accept">Présent</button>
                                </form>
                                {% endif %}
                                {% if p.presenceStatus != 'absent' %}
                                <form method="POST" action="{{ path('app_participation_presence', {'id': p.id, 'status': 'absent'}) }}" class="d-inline">
                                    <button type="submit" class="btn-sm-reject">Absent</button>
                                </form>
                                {% endif %}
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="4" class="empty-cell">Aucun participant inscrit.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<style>

.blob-bg {
    position: fixed; inset: 0; z-index: -1; overflow: hidden;
    background: radial-gradient(ellipse at 70% 40%, #e84c0e 0%, #b81c05 35%, #7a0a0e 65%, #2d0520 100%);
}
.blob { position: absolute; border-radius: 50%; mix-blend-mode: screen; filter: blur(2px); }
.blob-1 { width: 340px; height: 340px; background: radial-gradient(circle at 40% 35%, #ffaa00, #e85c00 55%, transparent 80%); top: -60px; right: 100px; animation: float1 9s ease-in-out infinite; }
.blob-2 { width: 180px; height: 180px; background: radial-gradient(circle at 45% 40%, #ffd060, #ff8800 60%, transparent 80%); top: 20px; right: 330px; animation: float2 11s ease-in-out infinite; }
.blob-3 { width: 420px; height: 360px; background: radial-gradient(circle at 50% 45%, #ff6a00 0%, #dd2200 50%, transparent 75%); bottom: -100px; right: -40px; animation: float3 13s ease-in-out infinite; }
.blob-4 { width: 260px; height: 200px; background: radial-gradient(circle at 50% 50%, #ff4500 0%, #9e0a00 55%, transparent 80%); bottom: 20px; left: 80px; animation: float4 10s ease-in-out infinite; }
.blob-5 { width: 90px; height: 90px; background: radial-gradient(circle at 45% 40%, #ffc040, #ff7800 60%, transparent 80%); top: 130px; right: 260px; animation: float5 7s ease-in-out infinite; }
@keyframes float1 { 0%,100% { transform: translate(0,0) scale(1); } 33% { transform: translate(-18px, 22px) scale(1.04); } 66% { transform: translate(12px, -14px) scale(0.97); } }
@keyframes float2 { 0%,100% { transform: translate(0,0) scale(1); } 40% { transform: translate(20px, 18px) scale(1.06); } 70% { transform: translate(-10px, -8px) scale(0.95); } }
@keyframes float3 { 0%,100% { transform: translate(0,0) scale(1); } 30% { transform: translate(-25px, -20px) scale(1.03); } 60% { transform: translate(15px, 12px) scale(0.98); } }
@keyframes float4 { 0%,100% { transform: translate(0,0) scale(1); } 45% { transform: translate(22px, -18px) scale(1.05); } 75% { transform: translate(-12px, 10px) scale(0.96); } }
@keyframes float5 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-14px, 20px) scale(1.1); } }

body { min-height: 100vh; }
::selection { background: rgba(232,92,0,0.3); }
::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,200,170,0.2); border-radius: 20px; }

.page { min-height: 100vh; }
.page .container { max-width: 1480px; }

.back-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: rgba(255,200,170,0.6); text-decoration: none;
    font-size: 0.85rem; font-weight: 500;
    padding: 7px 16px; border-radius: 50px;
    border: 1px solid rgba(255,140,50,0.15);
    background: rgba(232,92,0,0.08);
    transition: 0.2s ease;
}
.back-link:hover { color: white; background: rgba(232,92,0,0.18); }

.page-badge {
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white; padding: 6px 16px; border-radius: 50px;
    font-size: 0.82rem; font-weight: 600; letter-spacing: 1px;
    box-shadow: 0 2px 10px rgba(232,92,0,0.35);
}

.manage-card {
    background: rgba(18,5,20,0.5);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(255,140,50,0.12);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0,0,0,0.25);
}
.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(255,140,50,0.06);
}
.card-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: white;
    margin: 0;
}
.card-club {
    font-size: 0.75rem;
    color: rgba(255,200,170,0.4);
    font-weight: 600;
}

.manage-table {
    width: 100%;
    border-collapse: collapse;
}
.manage-table th {
    text-align: left;
    padding: 10px 14px;
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(255,200,170,0.4);
    text-transform: uppercase;
    letter-spacing: 0.6px;
    background: rgba(18,5,20,0.3);
    border-bottom: 1px solid rgba(255,140,50,0.06);
}
.manage-table td {
    padding: 10px 14px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.9);
    border-bottom: 1px solid rgba(255,140,50,0.04);
    vertical-align: middle;
}
.manage-table tr:last-child td { border-bottom: none; }
.empty-cell {
    color: rgba(255,200,170,0.3);
    text-align: center;
    padding: 2rem !important;
    font-size: 0.85rem;
}

.member-info {
    display: flex;
    align-items: center;
    gap: 10px;
}
.member-avatar {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.member-name { font-weight: 600; color: white; font-size: 0.85rem; }
.member-email { color: rgba(255,200,170,0.4); font-size: 0.72rem; }

.text-muted { color: rgba(255,200,170,0.4) !important; font-size: 0.8rem; }

.pc-status {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 2px 8px;
    border-radius: 50px;
    white-space: nowrap;
}
.pc-status.inscrit { background: rgba(99,102,241,0.1); color: #a5b4fc; border: 1px solid rgba(165,180,252,0.2); }
.pc-status.present { background: rgba(34,197,94,0.1); color: #4ade80; border: 1px solid rgba(74,222,128,0.2); }
.pc-status.absent  { background: rgba(220,53,69,0.1); color: #ff6b81; border: 1px solid rgba(255,107,129,0.2); }

.btn-sm-accept {
    padding: 5px 12px; border: none; border-radius: 8px;
    background: rgba(34,197,94,0.12); color: #4ade80;
    font-weight: 600; font-size: 0.75rem;
    cursor: pointer; transition: 0.2s; font-family: inherit;
    border: 1px solid rgba(74,222,128,0.2);
}
.btn-sm-accept:hover { background: rgba(34,197,94,0.2); }

.btn-sm-reject {
    padding: 5px 12px; border: none; border-radius: 8px;
    background: rgba(220,53,69,0.12); color: #ff6b81;
    font-weight: 600; font-size: 0.75rem;
    cursor: pointer; transition: 0.2s; font-family: inherit;
    border: 1px solid rgba(255,107,129,0.2);
}
.btn-sm-reject:hover { background: rgba(220,53,69,0.2); }

.alert-flash {
    padding: 12px 20px; border-radius: 12px;
    font-weight: 600; font-size: 0.9rem;
    backdrop-filter: blur(8px);
}
.alert-flash.success { background: rgba(232,92,0,0.12); border: 1px solid rgba(255,153,68,0.25); color: #ff9944; }
.alert-flash.error   { background: rgba(220,53,69,0.15); border: 1px solid rgba(255,107,129,0.3); color: #ff8a9e; }

</style>

{% endblock %}
