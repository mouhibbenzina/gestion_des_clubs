{% extends 'base.html.twig' %}

{% block title %}Rejoindre {{ club.name }}{% endblock %}

{% block body %}

{% include 'navbar/navbar.html.twig' %}

{# ── Animated blob background ── #}
<div class="blob-bg" id="blobBg" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>
</div>

<div class="join-page py-4">
    <div class="container">

        <div class="mb-4">
            <a href="{{ path('app_club_index') }}" class="back-link">
                ← Retour à la liste
            </a>
        </div>

        <div class="join-card">

            {% for flash in app.flashes('error') %}
                <div class="alert-flash error mb-4">{{ flash }}</div>
            {% endfor %}
            {% for flash in app.flashes('warning') %}
                <div class="alert-flash warning mb-4">{{ flash }}</div>
            {% endfor %}

            <!-- CLUB INFO -->
            <div class="d-flex align-items-center gap-4 mb-5">
                <div class="club-logo-box">
                    {% if club.logo %}
                        <img src="{{ asset('uploads/logos/' ~ club.logo) }}" alt="{{ club.name }}">
                    {% else %}
                        <div class="logo-initial">{{ club.name|slice(0,1)|upper }}</div>
                    {% endif %}
                </div>
                <div>
                    <span class="domain-badge mb-2 d-inline-block">{{ club.domain }}</span>
                    <h1 class="club-name">{{ club.name }}</h1>
                    <p class="club-desc">{{ club.description }}</p>
                </div>
            </div>

            <!-- CODE FORM -->
            <div class="code-section">
                <h2 class="code-title">Entrez le code d'accès</h2>
                <p class="code-subtitle">
                    Ce code vous est fourni par l'administrateur du club.
                </p>

                <form method="POST" action="{{ path('app_club_join', {'id': club.id}) }}">
                    <div class="code-input-wrapper">
                        <input
                            type="text"
                            name="code"
                            class="code-input"
                            placeholder="Ex: CLUB2024"
                            autocomplete="off"
                            autofocus
                            required
                        >
                        <button type="submit" class="join-submit-btn">
                            Rejoindre →
                        </button>
                    </div>
                </form>
            </div>

        </div>

    </div>
</div>

<style>

/* ── Animated blob background ── */
.blob-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background: radial-gradient(ellipse at 70% 40%, #e84c0e 0%, #b81c05 35%, #7a0a0e 65%, #2d0520 100%);
}

.blob {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: screen;
    filter: blur(2px);
}

.blob-1 {
    width: 340px; height: 340px;
    background: radial-gradient(circle at 40% 35%, #ffaa00, #e85c00 55%, transparent 80%);
    top: -60px; right: 100px;
    animation: float1 9s ease-in-out infinite;
}
.blob-2 {
    width: 180px; height: 180px;
    background: radial-gradient(circle at 45% 40%, #ffd060, #ff8800 60%, transparent 80%);
    top: 20px; right: 330px;
    animation: float2 11s ease-in-out infinite;
}
.blob-3 {
    width: 420px; height: 360px;
    background: radial-gradient(circle at 50% 45%, #ff6a00 0%, #dd2200 50%, transparent 75%);
    bottom: -100px; right: -40px;
    animation: float3 13s ease-in-out infinite;
}
.blob-4 {
    width: 260px; height: 200px;
    background: radial-gradient(circle at 50% 50%, #ff4500 0%, #9e0a00 55%, transparent 80%);
    bottom: 20px; left: 80px;
    animation: float4 10s ease-in-out infinite;
}
.blob-5 {
    width: 90px; height: 90px;
    background: radial-gradient(circle at 45% 40%, #ffc040, #ff7800 60%, transparent 80%);
    top: 130px; right: 260px;
    animation: float5 7s ease-in-out infinite;
}

.sparkle {
    position: absolute;
    width: 3px; height: 3px;
    background: rgba(255,255,255,0.55);
    border-radius: 50%;
}

@keyframes float1 {
    0%,100% { transform: translate(0,0) scale(1); }
    33% { transform: translate(-18px, 22px) scale(1.04); }
    66% { transform: translate(12px, -14px) scale(0.97); }
}
@keyframes float2 {
    0%,100% { transform: translate(0,0) scale(1); }
    40% { transform: translate(20px, 18px) scale(1.06); }
    70% { transform: translate(-10px, -8px) scale(0.95); }
}
@keyframes float3 {
    0%,100% { transform: translate(0,0) scale(1); }
    30% { transform: translate(-25px, -20px) scale(1.03); }
    60% { transform: translate(15px, 12px) scale(0.98); }
}
@keyframes float4 {
    0%,100% { transform: translate(0,0) scale(1); }
    45% { transform: translate(22px, -18px) scale(1.05); }
    75% { transform: translate(-12px, 10px) scale(0.96); }
}
@keyframes float5 {
    0%,100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(-14px, 20px) scale(1.1); }
}

body {
    min-height: 100vh;
    overflow-y: hidden;
}

::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,200,170,0.2); border-radius: 20px; }

.join-page .container {
    max-width: 1480px;
}
.join-page { min-height: 100vh; }

.back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,200,170,0.6);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 7px 16px;
    border-radius: 50px;
    border: 1px solid rgba(255,140,50,0.15);
    background: rgba(232,92,0,0.08);
    transition: 0.2s ease;
}
.back-link:hover {
    color: white;
    background: rgba(232,92,0,0.18);
}

.join-card {
    max-width: 680px;
    margin: 0 auto;
    background: rgba(18, 5, 20, 0.5);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(255,140,50,0.12);
    border-radius: 24px;
    padding: 3rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3);
}

.club-logo-box {
    flex-shrink: 0;
    width: 90px; height: 90px;
    border-radius: 20px;
    background: rgba(18,5,20,0.5);
    border: 1px solid rgba(255,140,50,0.1);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
}
.club-logo-box img {
    width: 100%; height: 100%;
    object-fit: contain; padding: 8px;
}
.logo-initial {
    font-size: 2.5rem; font-weight: 800; color: white;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    border-radius: 20px;
}

.domain-badge {
    background: rgba(232,92,0,0.15);
    border: 1px solid rgba(255,140,50,0.3);
    color: #ff9944;
    padding: 3px 12px;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
}

.club-name {
    font-size: 1.6rem;
    font-weight: 800;
    color: white;
    margin: 4px 0 6px;
}
.club-desc {
    color: rgba(255,200,170,0.55);
    font-size: 0.88rem;
    line-height: 1.6;
    margin: 0;
}

.code-section {
    background: rgba(18,5,20,0.4);
    border: 1px solid rgba(255,140,50,0.08);
    border-radius: 18px;
    padding: 2rem;
}

.code-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: white;
    margin-bottom: 6px;
}
.code-subtitle {
    color: rgba(255,200,170,0.45);
    font-size: 0.88rem;
    margin-bottom: 1.5rem;
}

.code-input-wrapper {
    display: flex;
    gap: 12px;
}

.code-input {
    flex: 1;
    background: rgba(18,5,20,0.4);
    border: 1px solid rgba(255,140,50,0.15);
    border-radius: 14px;
    padding: 14px 20px;
    color: white;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    outline: none;
    transition: 0.2s;
}
.code-input::placeholder {
    color: rgba(255,255,255,0.25);
    letter-spacing: 1px;
    text-transform: none;
}
.code-input:focus {
    border-color: #ff8c42;
    background: rgba(232,92,0,0.08);
}

.join-submit-btn {
    padding: 14px 28px;
    border-radius: 14px;
    background: linear-gradient(135deg, #e85c00, #b81c05);
    color: white;
    font-weight: 700;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
    transition: 0.2s ease;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(232,92,0,0.35);
}
.join-submit-btn:hover { opacity: 0.92; transform: scale(1.02); box-shadow: 0 6px 24px rgba(232,92,0,0.5); }

.alert-flash {
    padding: 12px 20px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.9rem;
    backdrop-filter: blur(8px);
}
.alert-flash.error   { background: rgba(220,53,69,0.15);  border: 1px solid rgba(255,107,129,0.3); color: #ff8a9e; }
.alert-flash.warning { background: rgba(232,92,0,0.1); border: 1px solid rgba(255,153,68,0.2);  color: #ff9944; }

</style>

<script>
(function() {
    const bg = document.getElementById('blobBg');
    if (!bg) return;
    const positions = [
        [12,8],[25,60],[40,25],[55,80],[68,15],[75,50],[85,35],[90,70],[5,45],[50,5],[30,90],[60,55],[80,20],[15,75],[45,40]
    ];
    positions.forEach(([left, top]) => {
        const s = document.createElement('div');
        s.className = 'sparkle';
        s.style.left = left + '%';
        s.style.top = top + '%';
        s.style.opacity = (0.2 + Math.random() * 0.5).toFixed(2);
        s.style.animation = `float${(Math.floor(Math.random()*5)+1)} ${6+Math.random()*8}s ease-in-out infinite`;
        s.style.animationDelay = (Math.random() * 4).toFixed(1) + 's';
        bg.appendChild(s);
    });
})();
</script>

{% endblock %}